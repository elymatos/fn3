    rdfs:subPropertyOf <dul:implements> .

ex:FormalSystemsScenario1 a dul:Situation ;
    rdfs:label "Scenario 1" .

ex:FormalSystemsScenario2 a dul:Situation ;
    rdfs:label "Scenario 2" .

ex:FormalSystemsScenario3 a dul:Situation ;
    rdfs:label "Scenario 3" .


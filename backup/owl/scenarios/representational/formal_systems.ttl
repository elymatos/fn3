ex:AbstractConcepts a owl:Class ;
    rdfs:label "AbstractConcepts" ;
    rdfs:comment "Ideas that exist independent of specific concrete instances" ;
    rdfs:subClassOf <dul:Concept> .

ex:AbstractLevel a owl:Class ;
    rdfs:label "AbstractLevel" ;
    rdfs:comment "Highly general, conceptual representations" ;
    rdfs:subClassOf <dul:State> .

ex:AbstractModeling a owl:Class ;
    rdfs:label "AbstractModeling" ;
    rdfs:comment "Creation of simplified representations of complex phenomena" ;
    rdfs:subClassOf <dul:Process> .

ex:AbstractProblems a owl:Class ;
    rdfs:label "AbstractProblems" ;
    rdfs:comment "Challenges requiring formal mathematical or logical solutions" ;
    rdfs:subClassOf <dul:Description> .

ex:AbstractionMechanisms a owl:Class ;
    rdfs:label "AbstractionMechanisms" ;
    rdfs:comment "Systematic methods for changing abstraction levels" ;
    rdfs:subClassOf <dul:Process> .

ex:ComplexPhenomena a owl:Class ;
    rdfs:label "ComplexPhenomena" ;
    rdfs:comment "Multi-faceted real-world processes or systems" ;
    rdfs:subClassOf <dul:Situation> .

ex:ComputationalLogic a owl:Class ;
    rdfs:label "ComputationalLogic" ;
    rdfs:comment "Reasoning principles suitable for automated execution" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:ConceptualStructures a owl:Class ;
    rdfs:label "ConceptualStructures" ;
    rdfs:comment "Organized systems of related concepts" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:DefinedProblems a owl:Class ;
    rdfs:label "DefinedProblems" ;
    rdfs:comment "Well-specified challenges with clear solution criteria" ;
    rdfs:subClassOf <dul:Description> .

ex:DetailedLevel a owl:Class ;
    rdfs:label "DetailedLevel" ;
    rdfs:comment "Highly specific, concrete representations" ;
    rdfs:subClassOf <dul:State> .

ex:ExpressiveConstraints a owl:Class ;
    rdfs:label "ExpressiveConstraints" ;
    rdfs:comment "Limits on what can be represented in the system" ;
    rdfs:subClassOf <dul:Quality> .

ex:FormalNotations a owl:Class ;
    rdfs:label "FormalNotations" ;
    rdfs:comment "Symbolic systems for representing mathematical and logical concepts" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:FormalSystemUpgrades a owl:Class ;
    rdfs:label "FormalSystemUpgrades" ;
    rdfs:comment "Systematic improvements to formal systems" ;
    rdfs:subClassOf <dul:Process> .

ex:FrameworkElements a owl:Class ;
    rdfs:label "FrameworkElements" ;
    rdfs:comment "Components of systematic frameworks" ;
    rdfs:subClassOf <dul:Object> .

ex:IntermediateLevel a owl:Class ;
    rdfs:label "IntermediateLevel" ;
    rdfs:comment "Moderate abstraction balancing detail and generality" ;
    rdfs:subClassOf <dul:State> .

ex:LevelMapping a owl:Class ;
    rdfs:label "LevelMapping" ;
    rdfs:comment "Creating correspondences between abstraction levels" ;
    rdfs:subClassOf <dul:Process> .

ex:LevelNavigation a owl:Class ;
    rdfs:label "LevelNavigation" ;
    rdfs:comment "Moving between different abstraction levels" ;
    rdfs:subClassOf <dul:Process> .

ex:LogicalConsistency a owl:Class ;
    rdfs:label "LogicalConsistency" ;
    rdfs:comment "Freedom from contradictions within the system" ;
    rdfs:subClassOf <dul:Quality> .

ex:LogicalStructures a owl:Class ;
    rdfs:label "LogicalStructures" ;
    rdfs:comment "Systematic frameworks for reasoning and inference" ;
    rdfs:subClassOf <dul:System> .

ex:QuantitativeRelationships a owl:Class ;
    rdfs:label "QuantitativeRelationships" ;
    rdfs:comment "Mathematical connections between quantities" ;
    rdfs:subClassOf <dul:Relation> .

ex:RepresentationalCoherence a owl:Class ;
    rdfs:label "RepresentationalCoherence" ;
    rdfs:comment "Consistency of meaning across abstraction levels" ;
    rdfs:subClassOf <dul:Quality> .

ex:RuleGeneralization a owl:Class ;
    rdfs:label "RuleGeneralization" ;
    rdfs:comment "Making rules more broadly applicable" ;
    rdfs:subClassOf <dul:Process> .

ex:ScaleTransition a owl:Class ;
    rdfs:label "ScaleTransition" ;
    rdfs:comment "Adjusting scope and granularity of representation" ;
    rdfs:subClassOf <dul:Process> .

ex:StepWiseAlgorithms a owl:Class ;
    rdfs:label "StepWiseAlgorithms" ;
    rdfs:comment "Procedures broken down into discrete, executable steps" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:SystemAdaptation a owl:Class ;
    rdfs:label "SystemAdaptation" ;
    rdfs:comment "Adjusting systems for new applications" ;
    rdfs:subClassOf <dul:Process> .

ex:SystematicExecution a owl:Class ;
    rdfs:label "SystematicExecution" ;
    rdfs:comment "Carrying out procedures following established steps" ;
    rdfs:subClassOf <dul:Process> .

ex:AbstractionSpecialist a owl:Class ;
    rdfs:label "AbstractionSpecialist" ;
    rdfs:comment "Person managing multiple levels of abstraction in representations" ;
    rdfs:subClassOf <dul:Agent> .

ex:AlgorithmDesigner a owl:Class ;
    rdfs:label "AlgorithmDesigner" ;
    rdfs:comment "Person creating systematic computational procedures" ;
    rdfs:subClassOf <dul:Agent> .

ex:AutomatableProcesses a owl:Class ;
    rdfs:label "AutomatableProcesses" ;
    rdfs:comment "Procedures that can be executed without human intervention" ;
    rdfs:subClassOf <dul:Process> .

ex:ComputationalModels a owl:Class ;
    rdfs:label "ComputationalModels" ;
    rdfs:comment "Abstract representations designed for computational processing" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:EssentialRelationships a owl:Class ;
    rdfs:label "EssentialRelationships" ;
    rdfs:comment "Key connections between model components" ;
    rdfs:subClassOf <dul:Relation> .

ex:FormalConclusions a owl:Class ;
    rdfs:label "FormalConclusions" ;
    rdfs:comment "Results derived through systematic application of formal rules" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:LogicalRules a owl:Class ;
    rdfs:label "LogicalRules" ;
    rdfs:comment "Principles governing valid reasoning and inference" ;
    rdfs:subClassOf <dul:Description> .

ex:LogicalSequences a owl:Class ;
    rdfs:label "LogicalSequences" ;
    rdfs:comment "Ordered steps following logical progression" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:ModelBuilder a owl:Class ;
    rdfs:label "ModelBuilder" ;
    rdfs:comment "Person creating theoretical models and systematic frameworks" ;
    rdfs:subClassOf <dul:Agent> .

ex:RuleModification a owl:Class ;
    rdfs:label "RuleModification" ;
    rdfs:comment "Changing existing rules within formal systems" ;
    rdfs:subClassOf <dul:Process> .

ex:SystemCapabilities a owl:Class ;
    rdfs:label "SystemCapabilities" ;
    rdfs:comment "Range of problems the system can address" ;
    rdfs:subClassOf <dul:Quality> .

ex:SystemLimitations a owl:Class ;
    rdfs:label "SystemLimitations" ;
    rdfs:comment "Constraints that restrict formal system capabilities" ;
    rdfs:subClassOf <dul:Description> .

ex:SystematicFrameworks a owl:Class ;
    rdfs:label "SystematicFrameworks" ;
    rdfs:comment "Organized structures for understanding complex systems" ;
    rdfs:subClassOf <dul:System> .

ex:SystematicProcedures a owl:Class ;
    rdfs:label "SystematicProcedures" ;
    rdfs:comment "Organized sequences of actions or operations" ;
    rdfs:subClassOf <dul:Process> .

ex:TheoreticalPredictions a owl:Class ;
    rdfs:label "TheoreticalPredictions" ;
    rdfs:comment "Forecasts derived from model applications" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:AbstractionTransitions a owl:Class ;
    rdfs:label "AbstractionTransitions" ;
    rdfs:comment "Movement between different levels of abstraction" ;
    rdfs:subClassOf <dul:Process> .

ex:ExistingFormalSystems a owl:Class ;
    rdfs:label "ExistingFormalSystems" ;
    rdfs:comment "Established mathematical or logical frameworks" ;
    rdfs:subClassOf <dul:System> .

ex:MathematicalOperations a owl:Class ;
    rdfs:label "MathematicalOperations" ;
    rdfs:comment "Formal procedures for manipulating mathematical expressions" ;
    rdfs:subClassOf <dul:Process> .

ex:MathematicalSystems a owl:Class ;
    rdfs:label "MathematicalSystems" ;
    rdfs:comment "Formal frameworks for quantitative and abstract reasoning" ;
    rdfs:subClassOf <dul:System> .

ex:MathematicalThinker a owl:Class ;
    rdfs:label "MathematicalThinker" ;
    rdfs:comment "Person working with formal mathematical and logical systems" ;

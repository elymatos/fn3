    rdfs:comment "works with" ;
    rdfs:domain ex:MathematicalThinker ;
    rdfs:range ex:LogicalStructures ;
    rdfs:subPropertyOf <dul:usesInstrument> .

ex:MathematicalThinkerToMathematicalOperations a owl:ObjectProperty ;

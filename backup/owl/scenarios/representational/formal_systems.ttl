@prefix dul: <http://www.loa-cnr.it/ontologies/DUL.owl#> .
@prefix ex: <http://example.org/needs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:AbstractModelingToComplexPhenomena a owl:ObjectProperty ;
    rdfs:comment "creates representations of" ;
    rdfs:domain ex:AbstractModeling ;
    rdfs:range ex:ComplexPhenomena ;
    rdfs:subPropertyOf <dul:represents> .

ex:AbstractionMechanismsToLevelNavigation a owl:ObjectProperty ;
    rdfs:comment "enable" ;
    rdfs:domain ex:AbstractionMechanisms ;
    rdfs:range ex:LevelNavigation ;
    rdfs:subPropertyOf <dul:enables> .

ex:AbstractionSpecialistToAbstractionTransitions a owl:ObjectProperty ;
    rdfs:comment "manages" ;

ex:SystemExtension a owl:Class ;
    rdfs:label "SystemExtension" ;
    rdfs:comment "Adding new capabilities to formal systems" ;
    rdfs:subClassOf <dul:Process> .

ex:AlgorithmicProcesses a owl:Class ;
    rdfs:label "AlgorithmicProcesses" ;
    rdfs:comment "Systematic step-by-step procedures for problem solving" ;
    rdfs:subClassOf <dul:Process> .

ex:ModelComponents a owl:Class ;
    rdfs:label "ModelComponents" ;
    rdfs:comment "Elements that make up theoretical models" ;
    rdfs:subClassOf <dul:Object> .

ex:SymbolicRepresentations a owl:Class ;
    rdfs:label "SymbolicRepresentations" ;
    rdfs:comment "Abstract symbols that represent concepts and relationships" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:TheoreticalModels a owl:Class ;
    rdfs:label "TheoreticalModels" ;
    rdfs:comment "Abstract representations of real-world phenomena" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:MultiLevelRepresentations a owl:Class ;
    rdfs:label "MultiLevelRepresentations" ;
    rdfs:comment "Systems with multiple levels of detail and abstraction" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:SystemEvolutionist a owl:Class ;
    rdfs:label "SystemEvolutionist" ;
    rdfs:comment "Person modifying and extending formal systems" ;

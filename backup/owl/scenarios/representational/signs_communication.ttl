ex:LanguageConventions a owl:Class ;
    rdfs:label "LanguageConventions" ;
    rdfs:comment "Accepted patterns of language use" ;
    rdfs:subClassOf <dul:Description> .

ex:LanguageLearner a owl:Class ;
    rdfs:label "LanguageLearner" ;
    rdfs:comment "Person acquiring new language and communication skills" ;

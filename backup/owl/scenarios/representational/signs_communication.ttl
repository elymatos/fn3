ex:AdditionalMeaning a owl:Class ;
    rdfs:label "AdditionalMeaning" ;
    rdfs:comment "Information conveyed beyond literal verbal content" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:ClarificationStrategies a owl:Class ;
    rdfs:label "ClarificationStrategies" ;
    rdfs:comment "Methods for making unclear communication clearer" ;
    rdfs:subClassOf <dul:Process> .

ex:CommunicationBreakdowns a owl:Class ;
    rdfs:label "CommunicationBreakdowns" ;
    rdfs:comment "Failures in successful message transmission" ;
    rdfs:subClassOf <dul:Situation> .

ex:CommunicationChannels a owl:Class ;
    rdfs:label "CommunicationChannels" ;
    rdfs:comment "Media through which messages are transmitted" ;
    rdfs:subClassOf <dul:Object> .

ex:CommunicationSystems a owl:Class ;
    rdfs:label "CommunicationSystems" ;
    rdfs:comment "Languages, sign systems, or symbolic codes" ;
    rdfs:subClassOf <dul:System> .

ex:CommunicativeEffectiveness a owl:Class ;
    rdfs:label "CommunicativeEffectiveness" ;
    rdfs:comment "Degree of successful meaning transmission" ;
    rdfs:subClassOf <dul:Quality> .

ex:CommunicativeFlow a owl:Class ;
    rdfs:label "CommunicativeFlow" ;
    rdfs:comment "Smooth, uninterrupted communication exchange" ;
    rdfs:subClassOf <dul:Quality> .

ex:CommunicativeGoals a owl:Class ;
    rdfs:label "CommunicativeGoals" ;
    rdfs:comment "Intended outcomes of language use" ;
    rdfs:subClassOf <dul:Description> .

ex:ConfirmationChecking a owl:Class ;
    rdfs:label "ConfirmationChecking" ;
    rdfs:comment "Verifying that messages have been understood correctly" ;
    rdfs:subClassOf <dul:Process> .

ex:ContextualFactors a owl:Class ;
    rdfs:label "ContextualFactors" ;
    rdfs:comment "Situational elements affecting meaning interpretation" ;
    rdfs:subClassOf <dul:State> .

ex:CulturalUnderstanding a owl:Class ;
    rdfs:label "CulturalUnderstanding" ;
    rdfs:comment "Comprehension of cultural contexts of language use" ;
    rdfs:subClassOf <dul:State> .

ex:EmotionalSubtext a owl:Class ;
    rdfs:label "EmotionalSubtext" ;
    rdfs:comment "Affective undertones in communication" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:ExplanationExpansion a owl:Class ;
    rdfs:label "ExplanationExpansion" ;
    rdfs:comment "Providing additional detail to clarify meaning" ;
    rdfs:subClassOf <dul:Process> .

ex:GesturePatterns a owl:Class ;
    rdfs:label "GesturePatterns" ;
    rdfs:comment "Hand movements and body language conveying meaning" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:GrammarLearning a owl:Class ;
    rdfs:label "GrammarLearning" ;
    rdfs:comment "Mastering structural rules of language" ;
    rdfs:subClassOf <dul:Process> .

ex:GrammaticalRules a owl:Class ;
    rdfs:label "GrammaticalRules" ;
    rdfs:comment "Principles governing how linguistic units combine" ;
    rdfs:subClassOf <dul:Description> .

ex:IntendedMeanings a owl:Class ;
    rdfs:label "IntendedMeanings" ;
    rdfs:comment "Concepts or information the sender wishes to communicate" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:InteractiveRepair a owl:Class ;
    rdfs:label "InteractiveRepair" ;
    rdfs:comment "Collaborative effort to resolve communication problems" ;
    rdfs:subClassOf <dul:Process> .

ex:InterpretedMeanings a owl:Class ;
    rdfs:label "InterpretedMeanings" ;
    rdfs:comment "Concepts understood by the receiver" ;

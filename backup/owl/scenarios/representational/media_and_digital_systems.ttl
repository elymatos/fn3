ex:ArchivalIntegrity a owl:Class ;
    rdfs:label "ArchivalIntegrity" ;
    rdfs:comment "Maintaining authenticity and completeness of preserved materials" ;
    rdfs:subClassOf <dul:Quality> .

ex:AudioElements a owl:Class ;
    rdfs:label "AudioElements" ;
    rdfs:comment "Sound, music, and audio content" ;

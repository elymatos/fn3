ex:AccessPatterns a owl:Class ;
    rdfs:label "AccessPatterns" ;
    rdfs:comment "Regular ways users interact with information" ;
    rdfs:subClassOf <dul:State> .

ex:AdaptiveAlgorithms a owl:Class ;
    rdfs:label "AdaptiveAlgorithms" ;
    rdfs:comment "Computational methods for automatic system adjustment" ;
    rdfs:subClassOf <dul:Process> .

ex:AdaptiveSystemManager a owl:Class ;
    rdfs:label "AdaptiveSystemManager" ;
    rdfs:comment "Person designing systems that automatically adjust to usage patterns" ;
    rdfs:subClassOf <dul:Agent> .

ex:AudioContent a owl:Class ;
    rdfs:label "AudioContent" ;
    rdfs:comment "Sound, speech, and audio information" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:AutomaticReorganization a owl:Class ;
    rdfs:label "AutomaticReorganization" ;
    rdfs:comment "Self-modification of information structures" ;
    rdfs:subClassOf <dul:Process> .

ex:CoherentInformationExperience a owl:Class ;
    rdfs:label "CoherentInformationExperience" ;
    rdfs:comment "Seamless interaction with diverse information types" ;
    rdfs:subClassOf <dul:State> .

ex:ConnectionSystems a owl:Class ;

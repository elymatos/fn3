ex:KnowledgeValidator a owl:Class ;
    rdfs:label "KnowledgeValidator" ;
    rdfs:comment "Person responsible for verifying knowledge accuracy and reliability" ;
    rdfs:subClassOf <dul:Agent> .

ex:MeaningStructures a owl:Class ;
    rdfs:label "MeaningStructures" ;
    rdfs:comment "Organized systems representing conceptual significance" ;
    rdfs:subClassOf <dul:System> .

ex:MultipleDomains a owl:Class ;
    rdfs:label "MultipleDomains" ;
    rdfs:comment "Different fields or areas of knowledge" ;
    rdfs:subClassOf <dul:Collection> .

ex:RepresentationSchemas a owl:Class ;
    rdfs:label "RepresentationSchemas" ;
    rdfs:comment "Systematic frameworks for organizing encoded knowledge" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:SemanticConnections a owl:Class ;
    rdfs:label "SemanticConnections" ;
    rdfs:comment "Links between concepts based on meaning relationships" ;
    rdfs:subClassOf <dul:Relation> .

ex:SemanticMaps a owl:Class ;
    rdfs:label "SemanticMaps" ;
    rdfs:comment "Representations showing meaning relationships spatially" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:SemanticNetworks a owl:Class ;
    rdfs:label "SemanticNetworks" ;

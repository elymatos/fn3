ex:KnowledgeStructures a owl:Class ;
    rdfs:label "KnowledgeStructures" ;
    rdfs:comment "Systematic organizations of information and understanding" ;
    rdfs:subClassOf <dul:System> .

ex:RepresentationFormats a owl:Class ;

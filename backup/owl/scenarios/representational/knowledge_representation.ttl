    rdfs:label "Scenario 2" .

ex:KnowledgeRepresentationScenario3 a dul:Situation ;
    rdfs:label "Scenario 3" .

ex:KnowledgeRepresentationScenario4 a dul:Situation ;
    rdfs:label "Scenario 4" .

ex:KnowledgeRepresentationScenario5 a dul:Situation ;
    rdfs:label "Scenario 5" .


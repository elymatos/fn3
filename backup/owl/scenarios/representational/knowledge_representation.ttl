ex:ConceptualBridges a owl:Class ;
    rdfs:label "ConceptualBridges" ;
    rdfs:comment "Conceptual links that connect different domains" ;
    rdfs:subClassOf <dul:Relation> .

ex:ConceptualMeaning a owl:Class ;
    rdfs:label "ConceptualMeaning" ;
    rdfs:comment "Significance and understanding associated with concepts" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:ConceptualModeling a owl:Class ;
    rdfs:label "ConceptualModeling" ;
    rdfs:comment "Creating abstract representations of knowledge domains" ;
    rdfs:subClassOf <dul:Process> .

ex:ConceptualRelationships a owl:Class ;
    rdfs:label "ConceptualRelationships" ;
    rdfs:comment "Meaningful connections between concepts" ;
    rdfs:subClassOf <dul:Relation> .

ex:ConsistencyChecking a owl:Class ;
    rdfs:label "ConsistencyChecking" ;
    rdfs:comment "Verifying logical coherence within knowledge systems" ;
    rdfs:subClassOf <dul:Process> .

ex:CrossDomainMapping a owl:Class ;
    rdfs:label "CrossDomainMapping" ;
    rdfs:comment "Identifying connections between different knowledge areas" ;
    rdfs:subClassOf <dul:Process> .

ex:DisparateKnowledge a owl:Class ;
    rdfs:label "DisparateKnowledge" ;
    rdfs:comment "Knowledge from separate, unconnected domains" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:DomainKnowledge a owl:Class ;
    rdfs:label "DomainKnowledge" ;
    rdfs:comment "Specialized understanding within particular fields" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:FactualValidation a owl:Class ;
    rdfs:label "FactualValidation" ;
    rdfs:comment "Checking claims against reliable evidence" ;
    rdfs:subClassOf <dul:Process> .

ex:HolisticPerspectives a owl:Class ;
    rdfs:label "HolisticPerspectives" ;
    rdfs:comment "Comprehensive view incorporating multiple knowledge domains" ;
    rdfs:subClassOf <dul:State> .

ex:KnowledgeApplication a owl:Class ;
    rdfs:label "KnowledgeApplication" ;
    rdfs:comment "Using encoded knowledge for practical purposes" ;
    rdfs:subClassOf <dul:Process> .

ex:KnowledgeConflicts a owl:Class ;
    rdfs:label "KnowledgeConflicts" ;
    rdfs:comment "Contradictions or inconsistencies in knowledge" ;
    rdfs:subClassOf <dul:Situation> .

ex:KnowledgeNavigation a owl:Class ;
    rdfs:label "KnowledgeNavigation" ;
    rdfs:comment "Moving through knowledge structures to find information" ;
    rdfs:subClassOf <dul:Process> .

ex:MeaningRelationships a owl:Class ;
    rdfs:label "MeaningRelationships" ;
    rdfs:comment "Various types of semantic connections between concepts" ;
    rdfs:subClassOf <dul:Relation> .

ex:RelationalStructures a owl:Class ;
    rdfs:label "RelationalStructures" ;
    rdfs:comment "Organizations based on relationship patterns" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:ReliabilityRanking a owl:Class ;
    rdfs:label "ReliabilityRanking" ;
    rdfs:comment "Ordering knowledge sources by trustworthiness" ;
    rdfs:subClassOf <dul:Process> .

ex:SemanticOrganization a owl:Class ;
    rdfs:label "SemanticOrganization" ;
    rdfs:comment "Organizing knowledge based on meaning relationships" ;
    rdfs:subClassOf <dul:Process> .

ex:SourceVerification a owl:Class ;
    rdfs:label "SourceVerification" ;
    rdfs:comment "Confirming credibility of knowledge origins" ;
    rdfs:subClassOf <dul:Process> .

ex:TacitUnderstanding a owl:Class ;
    rdfs:label "TacitUnderstanding" ;
    rdfs:comment "Implicit knowledge that is difficult to articulate" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:TruthAssessment a owl:Class ;
    rdfs:label "TruthAssessment" ;
    rdfs:comment "Evaluating correspondence between claims and reality" ;
    rdfs:subClassOf <dul:Process> .

ex:ConceptualFrameworks a owl:Class ;
    rdfs:label "ConceptualFrameworks" ;
    rdfs:comment "Organized systems for understanding and relating concepts" ;
    rdfs:subClassOf <dul:System> .

ex:ConceptualHierarchies a owl:Class ;

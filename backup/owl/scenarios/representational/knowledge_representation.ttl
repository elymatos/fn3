    rdfs:comment "New understanding that emerges from knowledge integration" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:ExplicitKnowledge a owl:Class ;
    rdfs:label "ExplicitKnowledge" ;
    rdfs:comment "Clearly articulated and documented understanding" ;

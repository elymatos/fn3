@prefix dul: <http://www.loa-cnr.it/ontologies/DUL.owl#> .
@prefix ex: <http://example.org/needs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:ConceptualBridgesToMultipleDomains a owl:ObjectProperty ;
    rdfs:comment "connect" ;
    rdfs:domain ex:ConceptualBridges ;
    rdfs:range ex:MultipleDomains ;
    rdfs:subPropertyOf <dul:connects> .

ex:ConceptualFrameworksToKnowledgeMaps a owl:ObjectProperty ;
    rdfs:comment "include" ;
    rdfs:domain ex:ConceptualFrameworks ;
    rdfs:range ex:KnowledgeMaps ;
    rdfs:subPropertyOf <dul:includes> .

ex:ConceptualHierarchiesToKnowledgeNavigation a owl:ObjectProperty ;

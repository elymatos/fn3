    rdfs:subClassOf <dul:Quality> .

ex:KnowledgeRetrieval a owl:Class ;
    rdfs:label "KnowledgeRetrieval" ;
    rdfs:comment "Accessing specific knowledge from encoded systems" ;
    rdfs:subClassOf <dul:Process> .

ex:KnowledgeSynthesizer a owl:Class ;
    rdfs:label "KnowledgeSynthesizer" ;
    rdfs:comment "Person combining knowledge from different domains" ;

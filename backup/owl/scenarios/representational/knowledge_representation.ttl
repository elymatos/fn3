ex:KnowledgeAccuracy a owl:Class ;
    rdfs:label "KnowledgeAccuracy" ;
    rdfs:comment "Correctness and precision of represented knowledge" ;
    rdfs:subClassOf <dul:Quality> .

ex:KnowledgeArchitect a owl:Class ;
    rdfs:label "KnowledgeArchitect" ;
    rdfs:comment "Person designing structures for organizing and representing knowledge" ;
    rdfs:subClassOf <dul:Agent> .

ex:KnowledgeConnections a owl:Class ;
    rdfs:label "KnowledgeConnections" ;
    rdfs:comment "Links and relationships between separate knowledge areas" ;
    rdfs:subClassOf <dul:Relation> .

ex:KnowledgeEngineer a owl:Class ;
    rdfs:label "KnowledgeEngineer" ;
    rdfs:comment "Person designing systems for encoding and representing knowledge" ;
    rdfs:subClassOf <dul:Agent> .

ex:KnowledgeIntegration a owl:Class ;
    rdfs:label "KnowledgeIntegration" ;
    rdfs:comment "Combining separate knowledge into unified understanding" ;

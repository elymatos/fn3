ex:VoluntaryComplianceToRegulatoryCompliance a owl:ObjectProperty ;
    rdfs:comment "achieves" ;
    rdfs:domain ex:VoluntaryCompliance ;
    rdfs:range ex:RegulatoryCompliance ;
    rdfs:subPropertyOf <dul:achieves> .

ex:Citizen a owl:Class ;
    rdfs:label "Citizen" ;
    rdfs:comment "Person with rights and obligations within political systems" ;
    rdfs:subClassOf <dul:Agent> .

ex:CivicEngagement a owl:Class ;
    rdfs:label "CivicEngagement" ;
    rdfs:comment "Broader participation in community and political life" ;
    rdfs:subClassOf <dul:Process> .

ex:ComplianceAudits a owl:Class ;
    rdfs:label "ComplianceAudits" ;
    rdfs:comment "Formal examinations of adherence to regulatory requirements" ;
    rdfs:subClassOf <dul:Process> .

ex:EnforcementMeasures a owl:Class ;
    rdfs:label "EnforcementMeasures" ;
    rdfs:comment "Specific actions taken to address non-compliance" ;
    rdfs:subClassOf <dul:Description> .

ex:EvidencePresentation a owl:Class ;
    rdfs:label "EvidencePresentation" ;
    rdfs:comment "Systematic presentation of facts and information" ;
    rdfs:subClassOf <dul:Process> .

ex:FairTreatment a owl:Class ;
    rdfs:label "FairTreatment" ;
    rdfs:comment "Equal and impartial handling according to legal standards" ;
    rdfs:subClassOf <dul:Quality> .

ex:GovernanceStrategies a owl:Class ;
    rdfs:label "GovernanceStrategies" ;
    rdfs:comment "Comprehensive approaches to governing and policy implementation" ;
    rdfs:subClassOf <dul:Description> .

ex:GovernmentalSystems a owl:Class ;
    rdfs:label "GovernmentalSystems" ;
    rdfs:comment "Formal structures for exercising political authority" ;
    rdfs:subClassOf <dul:System> .

ex:ImpactAssessment a owl:Class ;
    rdfs:label "ImpactAssessment" ;
    rdfs:comment "Evaluating potential effects of proposed policies" ;
    rdfs:subClassOf <dul:Process> .

ex:ImplementationChallenges a owl:Class ;
    rdfs:label "ImplementationChallenges" ;
    rdfs:comment "Obstacles encountered when putting policies into practice" ;
    rdfs:subClassOf <dul:Situation> .

ex:JuridicalProcesses a owl:Class ;
    rdfs:label "JuridicalProcesses" ;
    rdfs:comment "Formal procedures for legal decision-making and enforcement" ;
    rdfs:subClassOf <dul:Process> .

ex:JusticeSeeker a owl:Class ;
    rdfs:label "JusticeSeeker" ;
    rdfs:comment "Person seeking legal resolution of disputes or conflicts" ;
    rdfs:subClassOf <dul:Agent> .

ex:LegalConsequences a owl:Class ;
    rdfs:label "LegalConsequences" ;
    rdfs:comment "Results and penalties for legal violations or compliance" ;
    rdfs:subClassOf <dul:Situation> .

ex:LegalInstitutions a owl:Class ;
    rdfs:label "LegalInstitutions" ;
    rdfs:comment "Formal systems for administering justice (courts, tribunals)" ;
    rdfs:subClassOf <dul:System> .

ex:LegalParticipant a owl:Class ;
    rdfs:label "LegalParticipant" ;
    rdfs:comment "Person operating within formal legal and regulatory systems" ;
    rdfs:subClassOf <dul:Agent> .

ex:LegalProcedures a owl:Class ;
    rdfs:label "LegalProcedures" ;
    rdfs:comment "Formal steps in judicial decision-making" ;
    rdfs:subClassOf <dul:Process> .

ex:LegalRemedies a owl:Class ;
    rdfs:label "LegalRemedies" ;
    rdfs:comment "Formal solutions or compensation for legal violations" ;
    rdfs:subClassOf <dul:Description> .

ex:PolicyDecisions a owl:Class ;
    rdfs:label "PolicyDecisions" ;
    rdfs:comment "Formal choices about public issues and resource allocation" ;
    rdfs:subClassOf <dul:Description> .

ex:PolicyEffectiveness a owl:Class ;
    rdfs:label "PolicyEffectiveness" ;
    rdfs:comment "Degree to which policies achieve their intended goals" ;
    rdfs:subClassOf <dul:Quality> .

ex:PolicyMaker a owl:Class ;
    rdfs:label "PolicyMaker" ;
    rdfs:comment "Person responsible for developing and implementing public policies" ;
    rdfs:subClassOf <dul:Agent> .

ex:PoliticalAuthorities a owl:Class ;
    rdfs:label "PoliticalAuthorities" ;
    rdfs:comment "People holding formal governmental power" ;
    rdfs:subClassOf <dul:Agent> .

ex:PoliticalProcesses a owl:Class ;
    rdfs:label "PoliticalProcesses" ;
    rdfs:comment "Systematic procedures for collective decision-making and governance" ;
    rdfs:subClassOf <dul:Process> .

ex:RegulatoryIntegrity a owl:Class ;
    rdfs:label "RegulatoryIntegrity" ;
    rdfs:comment "Consistent and fair application of regulatory standards" ;
    rdfs:subClassOf <dul:Quality> .

ex:RegulatoryOfficer a owl:Class ;
    rdfs:label "RegulatoryOfficer" ;
    rdfs:comment "Person responsible for ensuring adherence to regulations and laws" ;
    rdfs:subClassOf <dul:Agent> .

ex:RegulatoryRequirements a owl:Class ;
    rdfs:label "RegulatoryRequirements" ;
    rdfs:comment "Specific compliance standards and procedures" ;
    rdfs:subClassOf <dul:Description> .

ex:StakeholderConsultation a owl:Class ;
    rdfs:label "StakeholderConsultation" ;
    rdfs:comment "Engaging relevant parties in policy development" ;
    rdfs:subClassOf <dul:Process> .

ex:VoluntaryCompliance a owl:Class ;
    rdfs:label "VoluntaryCompliance" ;
    rdfs:comment "Self-directed adherence to regulations without enforcement pressure" ;
    rdfs:subClassOf <dul:Process> .

ex:ComplianceMonitoring a owl:Class ;
    rdfs:label "ComplianceMonitoring" ;
    rdfs:comment "Systematic observation and assessment of adherence to regulations" ;
    rdfs:subClassOf <dul:Process> .

ex:ConflictResolution a owl:Class ;
    rdfs:label "ConflictResolution" ;
    rdfs:comment "Systematic approaches to resolving disputes" ;
    rdfs:subClassOf <dul:Process> .

ex:DemocraticParticipation a owl:Class ;
    rdfs:label "DemocraticParticipation" ;
    rdfs:comment "Active involvement in democratic decision-making" ;
    rdfs:subClassOf <dul:Process> .

ex:DisputeResolution a owl:Class ;
    rdfs:label "DisputeResolution" ;
    rdfs:comment "Successful conclusion of legal conflicts" ;
    rdfs:subClassOf <dul:State> .

ex:JudicialDecisionMaking a owl:Class ;
    rdfs:label "JudicialDecisionMaking" ;
    rdfs:comment "Formal determination of legal outcomes" ;
    rdfs:subClassOf <dul:Process> .

ex:JusticeOutcomes a owl:Class ;
    rdfs:label "JusticeOutcomes" ;
    rdfs:comment "Results that satisfy legal and moral standards of fairness" ;
    rdfs:subClassOf <dul:Description> .

ex:LegalDisputes a owl:Class ;
    rdfs:label "LegalDisputes" ;
    rdfs:comment "Conflicts requiring formal legal resolution" ;
    rdfs:subClassOf <dul:Situation> .

ex:LegalObligations a owl:Class ;
    rdfs:label "LegalObligations" ;
    rdfs:comment "Duties and requirements imposed by legal systems" ;
    rdfs:subClassOf <dul:Description> .

ex:LegalSystems a owl:Class ;
    rdfs:label "LegalSystems" ;
    rdfs:comment "Formal frameworks of laws, courts, and legal institutions" ;
    rdfs:subClassOf <dul:System> .

ex:PolicyFormulation a owl:Class ;
    rdfs:label "PolicyFormulation" ;
    rdfs:comment "Systematic development of policy proposals and plans" ;
    rdfs:subClassOf <dul:Process> .

ex:PolicyImplementation a owl:Class ;
    rdfs:label "PolicyImplementation" ;
    rdfs:comment "Putting approved policies into practice" ;
    rdfs:subClassOf <dul:Process> .

ex:PoliticalRights a owl:Class ;
    rdfs:label "PoliticalRights" ;
    rdfs:comment "Entitlements to participate in political processes" ;
    rdfs:subClassOf <dul:Description> .

ex:Regulations a owl:Class ;
    rdfs:label "Regulations" ;
    rdfs:comment "Detailed rules implementing broader legal principles" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:RegulatoryCompliance a owl:Class ;
    rdfs:label "RegulatoryCompliance" ;
    rdfs:comment "Adherence to established rules and regulations" ;
    rdfs:subClassOf <dul:State> .

ex:RegulatoryViolations a owl:Class ;
    rdfs:label "RegulatoryViolations" ;
    rdfs:comment "Instances of non-adherence to established regulations" ;
    rdfs:subClassOf <dul:Situation> .

ex:RepresentativeProcesses a owl:Class ;
    rdfs:label "RepresentativeProcesses" ;
    rdfs:comment "Systems where citizens influence governance through elected representatives" ;
    rdfs:subClassOf <dul:Process> .

ex:Voting a owl:Class ;
    rdfs:label "Voting" ;
    rdfs:comment "Formal selection of representatives or policies" ;
    rdfs:subClassOf <dul:Process> .

ex:EnforcementActions a owl:Class ;
    rdfs:label "EnforcementActions" ;
    rdfs:comment "Measures taken to ensure compliance with regulations" ;
    rdfs:subClassOf <dul:Process> .

ex:Laws a owl:Class ;
    rdfs:label "Laws" ;
    rdfs:comment "Formal rules established by governmental authority" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:LegalCompliance a owl:Class ;
    rdfs:label "LegalCompliance" ;
    rdfs:comment "Adherence to laws and regulatory requirements" ;
    rdfs:subClassOf <dul:Process> .

ex:PolicyOutcomes a owl:Class ;
    rdfs:label "PolicyOutcomes" ;
    rdfs:comment "Results and effects of implemented policies" ;
    rdfs:subClassOf <dul:Description> .

ex:PublicPolicies a owl:Class ;
    rdfs:label "PublicPolicies" ;
    rdfs:comment "Government decisions and plans that address societal issues" ;
    rdfs:subClassOf <dul:InformationObject> .


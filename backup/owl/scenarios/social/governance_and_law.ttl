    rdfs:comment "evaluates" ;
    rdfs:domain ex:ImpactAssessment ;
    rdfs:range ex:PublicPolicies ;
    rdfs:subPropertyOf <dul:evaluates> .

ex:ImplementationChallengesToPolicyOutcomes a owl:ObjectProperty ;
    rdfs:comment "affect" ;
    rdfs:domain ex:ImplementationChallenges ;
    rdfs:range ex:PolicyOutcomes ;
    rdfs:subPropertyOf <dul:affect> .

ex:JudicialDecisionMakingToJusticeOutcomes a owl:ObjectProperty ;
    rdfs:comment "determines" ;
    rdfs:domain ex:JudicialDecisionMaking ;
    rdfs:range ex:JusticeOutcomes ;
    rdfs:subPropertyOf <dul:determines> .

ex:JusticeOutcomesToFairTreatment a owl:ObjectProperty ;
    rdfs:comment "satisfy" ;
    rdfs:domain ex:JusticeOutcomes ;
    rdfs:range ex:FairTreatment ;
    rdfs:subPropertyOf <dul:satisfy> .

ex:JusticeSeekerToLegalDisputes a owl:ObjectProperty ;

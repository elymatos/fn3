    rdfs:comment "developed by" ;
    rdfs:domain ex:PublicPolicies ;
    rdfs:range ex:PolicyFormulation ;
    rdfs:subPropertyOf <dul:developedBy> .

ex:RegulationsToRegulatoryRequirements a owl:ObjectProperty ;
    rdfs:comment "specify" ;
    rdfs:domain ex:Regulations ;
    rdfs:range ex:RegulatoryRequirements ;
    rdfs:subPropertyOf <dul:specify> .

ex:RegulatoryIntegrityToEnforcementActions a owl:ObjectProperty ;
    rdfs:comment "maintained by" ;
    rdfs:domain ex:RegulatoryIntegrity ;
    rdfs:range ex:EnforcementActions ;
    rdfs:subPropertyOf <dul:maintainedBy> .


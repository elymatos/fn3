    rdfs:comment "resolved by" ;
    rdfs:domain ex:LegalDisputes ;
    rdfs:range ex:ConflictResolution ;
    rdfs:subPropertyOf <dul:resolvedBy> .

ex:LegalInstitutionsToConflictResolution a owl:ObjectProperty ;
    rdfs:comment "perform" ;
    rdfs:domain ex:LegalInstitutions ;
    rdfs:range ex:ConflictResolution ;
    rdfs:subPropertyOf <dul:perform> .

ex:LegalParticipantToLegalSystems a owl:ObjectProperty ;
    rdfs:comment "participates in" ;
    rdfs:domain ex:LegalParticipant ;
    rdfs:range ex:LegalSystems ;
    rdfs:subPropertyOf <dul:participatesIn> .

ex:LegalProceduresToEvidencePresentation a owl:ObjectProperty ;
    rdfs:comment "include" ;
    rdfs:domain ex:LegalProcedures ;
    rdfs:range ex:EvidencePresentation ;
    rdfs:subPropertyOf <dul:include> .

ex:LegalRemediesToDisputeResolution a owl:ObjectProperty ;
    rdfs:comment "provided in" ;
    rdfs:domain ex:LegalRemedies ;
    rdfs:range ex:DisputeResolution ;
    rdfs:subPropertyOf <dul:providedIn> .

ex:LegalSystemsToLaws a owl:ObjectProperty ;
    rdfs:comment "include" ;
    rdfs:domain ex:LegalSystems ;
    rdfs:range ex:Laws ;
    rdfs:subPropertyOf <dul:includes> .

ex:PolicyEffectivenessToPolicyOutcomes a owl:ObjectProperty ;
    rdfs:comment "assesses" ;
    rdfs:domain ex:PolicyEffectiveness ;
    rdfs:range ex:PolicyOutcomes ;
    rdfs:subPropertyOf <dul:assesses> .

ex:PolicyImplementationToPolicyOutcomes a owl:ObjectProperty ;
    rdfs:comment "produces" ;
    rdfs:domain ex:PolicyImplementation ;

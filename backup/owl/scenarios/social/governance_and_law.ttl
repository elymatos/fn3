@prefix dul: <http://www.loa-cnr.it/ontologies/DUL.owl#> .
@prefix ex: <http://example.org/needs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:CitizenToPoliticalRights a owl:ObjectProperty ;
    rdfs:comment "has right to" ;
    rdfs:domain ex:Citizen ;
    rdfs:range ex:PoliticalRights ;
    rdfs:subPropertyOf <dul:hasRight> .

ex:CivicEngagementToVoting a owl:ObjectProperty ;
    rdfs:comment "complements" ;
    rdfs:domain ex:CivicEngagement ;
    rdfs:range ex:Voting ;
    rdfs:subPropertyOf <dul:complements> .

ex:ComplianceAuditsToComplianceMonitoring a owl:ObjectProperty ;
    rdfs:comment "support" ;
    rdfs:domain ex:ComplianceAudits ;
    rdfs:range ex:ComplianceMonitoring ;
    rdfs:subPropertyOf <dul:support> .

ex:ComplianceMonitoringToRegulatoryViolations a owl:ObjectProperty ;
    rdfs:comment "detects" ;
    rdfs:domain ex:ComplianceMonitoring ;
    rdfs:range ex:RegulatoryViolations ;
    rdfs:subPropertyOf <dul:detects> .

ex:DemocraticParticipationToVoting a owl:ObjectProperty ;
    rdfs:comment "realized by" ;
    rdfs:domain ex:DemocraticParticipation ;
    rdfs:range ex:Voting ;
    rdfs:subPropertyOf <dul:realizedBy> .

ex:DisputeResolutionToJudicialDecisionMaking a owl:ObjectProperty ;
    rdfs:comment "results from" ;
    rdfs:domain ex:DisputeResolution ;
    rdfs:range ex:JudicialDecisionMaking ;
    rdfs:subPropertyOf <dul:resultsFrom> .

ex:EnforcementActionsToRegulatoryViolations a owl:ObjectProperty ;
    rdfs:comment "respond to" ;
    rdfs:domain ex:EnforcementActions ;
    rdfs:range ex:RegulatoryViolations ;
    rdfs:subPropertyOf <dul:respondTo> .

ex:EnforcementMeasuresToEnforcementActions a owl:ObjectProperty ;
    rdfs:comment "applied through" ;
    rdfs:domain ex:EnforcementMeasures ;
    rdfs:range ex:EnforcementActions ;
    rdfs:subPropertyOf <dul:appliedThrough> .

ex:GovernanceScenario1 a dul:Situation ;
    rdfs:label "Scenario 1" .

ex:GovernanceScenario2 a dul:Situation ;
    rdfs:label "Scenario 2" .

ex:GovernanceScenario3 a dul:Situation ;
    rdfs:label "Scenario 3" .

ex:GovernanceScenario4 a dul:Situation ;
    rdfs:label "Scenario 4" .

ex:GovernanceScenario5 a dul:Situation ;
    rdfs:label "Scenario 5" .


    rdfs:domain ex:JusticeSeeker ;
    rdfs:range ex:LegalDisputes ;
    rdfs:subPropertyOf <dul:initiates> .

ex:LawsToLegalObligations a owl:ObjectProperty ;
    rdfs:comment "impose" ;
    rdfs:domain ex:Laws ;
    rdfs:range ex:LegalObligations ;
    rdfs:subPropertyOf <dul:impose> .

ex:LawsToRegulations a owl:ObjectProperty ;
    rdfs:comment "implemented by" ;
    rdfs:domain ex:Laws ;
    rdfs:range ex:Regulations ;
    rdfs:subPropertyOf <dul:implementedBy> .

ex:LegalComplianceToJuridicalProcesses a owl:ObjectProperty ;
    rdfs:comment "ensured by" ;
    rdfs:domain ex:LegalCompliance ;
    rdfs:range ex:JuridicalProcesses ;
    rdfs:subPropertyOf <dul:ensuredBy> .

ex:LegalComplianceToLegalObligations a owl:ObjectProperty ;
    rdfs:comment "realizes" ;
    rdfs:domain ex:LegalCompliance ;
    rdfs:range ex:LegalObligations ;
    rdfs:subPropertyOf <dul:realizes> .


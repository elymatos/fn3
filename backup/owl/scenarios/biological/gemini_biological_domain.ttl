@prefix bio: <http://example.org/gemini/biological#> .
@prefix dul: <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#> .
@prefix ex: <http://example.org/gemini/health#> .
@prefix ex1: <http://example.org/gemini#> .
@prefix ex2: <http://example.org/gemini/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/gemini> a owl:Ontology ;
    owl:imports <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl> .

ex1:EcologicalStudy a dul:Situation ;
    dul:hasParticipant ex1:EcologyObserver,
        ex1:InteractingSpecies ;
    dul:hasSetting ex1:InterspeciesRelationships ;
    rdfs:comment "A situation in which an EcologyObserver studies InteractingSpecies engaged in InterspeciesRelationships." ;
    rdfs:subClassOf bio:BiologicalScenario .

ex1:ReproductiveObservation a dul:Situation ;
    dul:hasParticipant ex1:ReproducingOrganisms,
        ex1:ReproductionObserver ;
    dul:hasSetting ex1:GeneticTransmission,
        ex1:ReproductiveProcesses ;
    rdfs:comment "A situation in which a ReproductionObserver studies ReproductiveProcesses and GeneticTransmission in ReproducingOrganisms." ;
    rdfs:subClassOf bio:BiologicalScenario .

ex1:TrackingSituation a dul:Situation ;
    dul:hasParticipant ex1:LifeObserver,
        ex1:LivingOrganisms ;
    dul:hasSetting ex1:DevelopmentalStages ;
    rdfs:comment "A situation in which a LifeObserver tracks a LivingOrganism through DevelopmentalStages." ;
    rdfs:subClassOf bio:BiologicalScenario .

ex1:TraitBasedIdentification a dul:Situation ;
    dul:hasParticipant ex1:BiologicalClassifier ;
    dul:hasSetting ex1:BehavioralTraits,
        ex1:MorphologicalFeatures,
        ex1:SpeciesIdentification ;
    rdfs:comment "A classification act where a BiologicalClassifier identifies species using MorphologicalFeatures and BehavioralTraits." ;
    rdfs:subClassOf bio:BiologicalScenario .

ex1:VitalSignsObservation a dul:Situation ;
    dul:hasParticipant ex1:ActiveOrganisms,
        ex1:BiologicalMonitor ;
    dul:hasSetting ex1:VitalSigns ;
    rdfs:comment "A situation in which a BiologicalMonitor observes VitalSigns in ActiveOrganisms." ;
    rdfs:subClassOf bio:BiologicalScenario .

ex1:appearIn a owl:ObjectProperty ;
    rdfs:domain ex1:HereditaryTraits ;
    rdfs:range ex1:OffspringProduction ;
    rdfs:subPropertyOf dul:associatedWith .

ex1:carriedIn a owl:ObjectProperty ;
    rdfs:domain ex1:HereditaryTraits ;
    rdfs:range ex1:GeneticMaterial .

ex1:classifies rdfs:subPropertyOf dul:classifies .

ex1:demonstrate a owl:ObjectProperty ;
    rdfs:domain ex1:BiologicalActivities ;
    rdfs:range ex1:LifeFunctions ;
    rdfs:subPropertyOf dul:realizes .

ex1:dependsOn a owl:ObjectProperty ;
    rdfs:domain ex1:SpeciesContinuity ;
    rdfs:range ex1:OffspringProduction ;
    rdfs:subPropertyOf dul:hasCause .

ex1:determinePattern a owl:ObjectProperty ;
    rdfs:domain ex1:SpeciesCharacteristics ;
    rdfs:range ex1:LifeCyclePatterns ;
    rdfs:subPropertyOf dul:hasRegion .

ex1:determinePlacement a owl:ObjectProperty ;
    rdfs:domain ex1:SpeciesDistinctions ;
    rdfs:range ex1:TaxonomicCategories ;
    rdfs:subPropertyOf dul:classifies .

ex1:determineTransmission a owl:ObjectProperty ;
    rdfs:domain ex1:InheritancePatterns ;
    rdfs:range ex1:HereditaryTraits .

ex1:displayFunction a owl:ObjectProperty ;
    rdfs:domain ex1:ActiveOrganisms ;
    rdfs:range ex1:LifeFunctions .

ex1:driveTransitions a owl:ObjectProperty ;
    rdfs:domain ex1:GrowthProcesses ;
    rdfs:range ex1:DevelopmentalStages .

ex1:emergeFrom a owl:ObjectProperty ;
    rdfs:domain ex1:BiologicalCommunities ;
    rdfs:range ex1:InterspeciesRelationships .

ex1:enable a owl:ObjectProperty ;
    rdfs:domain ex1:SurvivalStrategies ;
    rdfs:range ex1:InterspeciesRelationships ;
    rdfs:subPropertyOf dul:hasRole .

ex1:encompasses a owl:ObjectProperty ;
    rdfs:domain ex1:BiologicalDiversity ;
    rdfs:range ex1:OrganismVariety .

ex1:engageIn a owl:ObjectProperty ;
    rdfs:domain ex1:InteractingSpecies ;
    rdfs:range ex1:InterspeciesRelationships ;
    rdfs:subPropertyOf dul:isParticipantIn .

ex1:ensure a owl:ObjectProperty ;
    rdfs:domain ex1:InheritancePatterns ;
    rdfs:range ex1:SpeciesContinuity ;
    rdfs:subPropertyOf dul:associatedWith .

ex1:followsPattern a owl:ObjectProperty ;
    rdfs:domain ex1:DevelopmentalStages ;
    rdfs:range ex1:LifeCyclePatterns .

ex1:foundIn a owl:ObjectProperty ;
    rdfs:domain ex1:VitalSigns ;
    rdfs:range ex1:ActiveOrganisms .

ex1:include a owl:ObjectProperty ;
    rdfs:domain ex1:BiologicalActivities,
        ex1:ClassificationSystems,
        ex1:InterspeciesRelationships ;
    rdfs:range ex1:Breathing,
        ex1:Competition,
        ex1:Cooperation,
        ex1:Feeding,
        ex1:Movement,
        ex1:Predation,
        ex1:Reproduction,
        ex1:Symbiosis,
        ex1:TaxonomicCategories .

ex1:includes rdfs:subPropertyOf dul:hasPart .

ex1:involve a owl:ObjectProperty ;
    rdfs:domain ex1:ReproductiveProcesses ;
    rdfs:range ex1:GeneticTransmission,
        ex1:MatingBehaviors ;
    rdfs:subPropertyOf dul:hasPart .

ex1:maintain a owl:ObjectProperty ;
    rdfs:domain ex1:LifeFunctions ;
    rdfs:range ex1:ActiveOrganisms ;
    rdfs:subPropertyOf dul:realizes .

ex1:markBoundariesOf a owl:ObjectProperty ;
    rdfs:domain ex1:BiologicalTransitions ;
    rdfs:range ex1:DevelopmentalStages .

ex1:observes a owl:ObjectProperty ;
    rdfs:domain ex1:BiologicalMonitor ;
    rdfs:range ex1:VitalSigns ;
    rdfs:subPropertyOf dul:observes .

ex1:observesFor a owl:ObjectProperty ;
    rdfs:domain ex1:BiologicalClassifier ;
    rdfs:range ex1:OrganismVariety .

ex1:occupy a owl:ObjectProperty ;
    rdfs:domain ex1:InteractingSpecies ;
    rdfs:range ex1:EcologicalNiches ;
    rdfs:subPropertyOf dul:hasLocation .

ex1:organize a owl:ObjectProperty ;
    rdfs:domain ex1:TaxonomicCategories ;
    rdfs:range ex1:BiologicalDiversity .

ex1:progressesFrom a owl:ObjectProperty ;
    rdfs:domain ex1:LivingOrganisms ;
    rdfs:range ex1:InitialStates .

ex1:progressesTo a owl:ObjectProperty ;
    rdfs:domain ex1:LivingOrganisms ;
    rdfs:range ex1:MatureStates .

ex1:recognizesThrough a owl:ObjectProperty ;
    rdfs:domain ex1:LifeObserver ;
    rdfs:range ex1:GrowthProcesses .

ex1:reduce a owl:ObjectProperty ;
    rdfs:domain ex1:EcologicalNiches ;
    rdfs:range ex1:Competition ;
    rdfs:subPropertyOf dul:hasEffect .

ex1:reflect a owl:ObjectProperty ;
    rdfs:domain ex1:ClassificationSystems ;
    rdfs:range ex1:PhylogeneticRelationships .

ex1:reliesOn a owl:ObjectProperty ;
    rdfs:domain ex1:SpeciesIdentification ;
    rdfs:range ex1:BehavioralTraits,
        ex1:MorphologicalFeatures ;
    rdfs:subPropertyOf dul:hasRegion .

ex1:resultsFrom a owl:ObjectProperty ;
    rdfs:domain ex1:OffspringProduction ;
    rdfs:range ex1:ReproductiveProcesses ;
    rdfs:subPropertyOf dul:hasCause .

ex1:serveAs a owl:ObjectProperty ;
    rdfs:domain ex1:VitalSigns ;
    rdfs:range ex1:LifeIndicators ;
    rdfs:subPropertyOf dul:hasRole .

ex1:studies a owl:ObjectProperty ;
    rdfs:domain ex1:EcologyObserver,
        ex1:ReproductionObserver ;
    rdfs:range ex1:InteractingSpecies,
        ex1:ReproductiveProcesses ;
    rdfs:subPropertyOf dul:observes .

ex1:tracks a owl:ObjectProperty ;
    rdfs:domain ex1:LifeObserver ;
    rdfs:range ex1:LivingOrganisms ;
    rdfs:subPropertyOf dul:observes .

ex1:transfers a owl:ObjectProperty ;
    rdfs:domain ex1:GeneticTransmission ;
    rdfs:range ex1:GeneticMaterial ;
    rdfs:subPropertyOf dul:hasParticipant .

ex1:usesSystem a owl:ObjectProperty ;
    rdfs:domain ex1:BiologicalClassifier ;
    rdfs:range ex1:ClassificationSystems ;
    rdfs:subPropertyOf dul:usesDescription .

ex1:usesToIdentify a owl:ObjectProperty ;
    rdfs:domain ex1:BiologicalMonitor ;
    rdfs:range ex1:LifeIndicators .

ex2:AdaptationProcesses rdfs:subClassOf bio:BiologicalProcess .

ex2:BodyGrowth rdfs:subClassOf bio:BiologicalProcess .

ex2:BodyParts rdfs:subClassOf bio:BiologicalStructure .

ex2:BodyPerceiver rdfs:subClassOf bio:BiologicalAgent .

ex2:ChangeObserver rdfs:subClassOf bio:BiologicalObserver .

ex2:ChronobiologyExpert rdfs:subClassOf bio:BiologicalObserver .

ex2:ConservationBiologist rdfs:subClassOf bio:BiologicalObserver .

ex2:ConservationStrategies rdfs:subClassOf bio:BiologicalProcess .

ex2:EcologicalFitness rdfs:subClassOf bio:BiologicalQuality .

ex2:EcologicalObserver rdfs:subClassOf bio:BiologicalObserver .

ex2:EcosystemAnalyst rdfs:subClassOf bio:BiologicalObserver .

ex2:EcosystemValue rdfs:subClassOf bio:BiologicalQuality .

ex2:EnvironmentalConditions rdfs:subClassOf bio:EnvironmentalFactor .

ex2:EnvironmentalPressures rdfs:subClassOf bio:EnvironmentalFactor .

ex2:EnvironmentalStressors rdfs:subClassOf bio:EnvironmentalFactor .

ex2:InternalStructures rdfs:subClassOf bio:BiologicalStructure .

ex2:MotorController rdfs:subClassOf bio:BiologicalAgent .

ex2:MotorPlanning rdfs:subClassOf bio:BiologicalProcess .

ex2:MovementExecution rdfs:subClassOf bio:BiologicalProcess .

ex2:NaturalDisruptions rdfs:subClassOf bio:EnvironmentalFactor .

ex2:PhysiologicalChallenges rdfs:subClassOf bio:EnvironmentalFactor .

ex2:PhysiologyMonitor rdfs:subClassOf bio:BiologicalObserver .

ex2:RecoveryProcesses rdfs:subClassOf bio:BiologicalProcess .

ex2:ResourceAvailability rdfs:subClassOf bio:BiologicalState .

ex2:SpeciesDistribution rdfs:subClassOf bio:BiologicalState .

ex2:SpeciesRichness rdfs:subClassOf bio:BiologicalQuality .

ex2:StressResearcher rdfs:subClassOf bio:BiologicalObserver .

ex2:StressResilience rdfs:subClassOf bio:BiologicalQuality .

ex2:StressResponses rdfs:subClassOf bio:BiologicalProcess .

ex2:body a owl:Ontology ;
    owl:imports <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl> .

ex2:ecology a owl:Ontology ;
    owl:imports <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl> .

ex2:health a owl:Ontology ;
    owl:imports <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl> .

ex:AnatomicalDevelopmentSituation a dul:Situation ;
    dul:hasParticipant ex:DevelopmentalObserver ;
    dul:hasSetting ex:BodyGrowth,
        ex:DevelopmentalMilestones,
        ex:StructuralChanges ;
    rdfs:comment "A situation where a DevelopmentalObserver monitors BodyGrowth and StructuralChanges through DevelopmentalMilestones." ;
    rdfs:subClassOf bio:BiologicalScenario .

ex:AnatomyMappingSituation a dul:Situation ;
    dul:hasParticipant ex:AnatomicalObserver ;
    dul:hasSetting ex:AnatomicalStructures,
        ex:BodyParts,
        ex:SpatialRelationships ;
    rdfs:comment "A situation in which an AnatomicalObserver identifies BodyParts and understands their SpatialRelationships within AnatomicalStructures." ;
    rdfs:subClassOf bio:BiologicalScenario .

ex:BiodiversityProtectionSituation a dul:Situation ;
    dul:hasParticipant ex:ConservationBiologist ;
    dul:hasSetting ex:ConservationStrategies,
        ex:ProtectionMeasures,
        ex:ThreatenedSpecies ;
    rdfs:comment "A situation in which a ConservationBiologist implements ProtectionMeasures and ConservationStrategies to safeguard ThreatenedSpecies." ;
    rdfs:subClassOf bio:BiologicalScenario .

ex:BodyAwarenessSituation a dul:Situation ;
    dul:hasParticipant ex:BodyPerceiver ;
    dul:hasSetting ex:ExternalFeatures,
        ex:InternalStructures,
        ex:VisibilityDifferences ;
    rdfs:comment "A situation in which a BodyPerceiver uses DirectObservation and ProprioceptiveAwareness to distinguish ExternalFeatures from InternalStructures." ;
    rdfs:subClassOf bio:BiologicalScenario .

ex:BodyProportionAnalysisSituation a dul:Situation ;
    dul:hasParticipant ex:ProportionAnalyst ;
    dul:hasSetting ex:BodyProportions,
        ex:BodySymmetry,
        ex:ProportionalRelationships ;
    rdfs:comment "A situation where a ProportionAnalyst examines BodySymmetry and ProportionalRelationships to understand BodyProportions." ;
    rdfs:subClassOf bio:BiologicalScenario .

ex:ChronobiologicalCoordinationSituation a dul:Situation ;
    dul:hasParticipant ex:ChronobiologyExpert ;
    dul:hasSetting ex:CircadianRhythms,
        ex:RhythmicHarmony,
        ex:SynchronizationMechanisms ;
    rdfs:comment "A situation where a ChronobiologyExpert studies CircadianRhythms and SynchronizationMechanisms leading to RhythmicHarmony." ;
    rdfs:subClassOf bio:BiologicalScenario .

ex:DisturbanceResponseSituation a dul:Situation ;
    dul:hasParticipant ex:ChangeObserver ;
    dul:hasSetting ex:AdaptationProcesses,
        ex:EcosystemRecovery,
        ex:EnvironmentalDisturbances ;
    rdfs:comment "A situation where a ChangeObserver monitors EnvironmentalDisturbances and their effect on AdaptationProcesses and EcosystemRecovery." ;
    rdfs:subClassOf bio:BiologicalScenario .

ex:EcosystemFlowSituation a dul:Situation ;
    dul:hasParticipant ex:EcosystemAnalyst ;
    dul:hasSetting ex:EcologicalNetworks,
        ex:EnergyTransfer,
        ex:ResourceFlows ;
    rdfs:comment "A situation where an EcosystemAnalyst tracks ResourceFlows and EnergyTransfer within EcologicalNetworks." ;
    rdfs:subClassOf bio:BiologicalScenario .

ex:EcosystemServiceSituation a dul:Situation ;
    dul:hasParticipant ex:EcosystemManager ;
    dul:hasSetting ex:EcosystemServices,
        ex:HumanCommunities,
        ex:ServiceProvision ;
    rdfs:comment "A situation in which an EcosystemManager evaluates the ServiceProvision of EcosystemServices to HumanCommunities." ;
    rdfs:subClassOf bio:BiologicalScenario .

ex:HabitatAdaptationSituation a dul:Situation ;
    dul:hasParticipant ex:EcologicalObserver ;
    dul:hasSetting ex:AdaptiveTraits,
        ex:EnvironmentalConditions,
        ex:OrganismGroups ;
    rdfs:comment "A situation in which an EcologicalObserver studies how OrganismGroups develop AdaptiveTraits in response to EnvironmentalConditions." ;
    rdfs:subClassOf bio:BiologicalScenario .

ex:HealthAssessmentSituation a dul:Situation ;
    dul:hasParticipant ex:HealthMonitor,
        ex:Individual ;
    dul:hasSetting ex:BehavioralChanges,
        ex:BodySignals,
        ex:IllnessSymptoms ;
    rdfs:comment "A situation where a HealthMonitor interprets BodySignals and BehavioralChanges in an Individual to assess IllnessSymptoms." ;
    rdfs:subClassOf bio:BiologicalScenario .

ex:LivingSystems a owl:Class ;
    rdfs:subClassOf dul:Object .

ex:MentalHealthSupportSituation a dul:Situation ;
    dul:hasParticipant ex:MentalHealthAssessor ;
    dul:hasSetting ex:CopingMechanisms,
        ex:MentalHealthStatus,
        ex:PsychologicalRecovery ;
    rdfs:comment "A situation in which a MentalHealthAssessor evaluates MentalHealthStatus and provides CopingMechanisms to support PsychologicalRecovery." ;
    rdfs:subClassOf bio:BiologicalScenario .

ex:MotorExecutionSituation a dul:Situation ;
    dul:hasParticipant ex:MotorController ;
    dul:hasSetting ex:MotorPlanning,
        ex:MovementExecution,
        ex:MovementPrecision ;
    rdfs:comment "A situation where a MotorController performs MotorPlanning and MovementExecution with MovementPrecision." ;
    rdfs:subClassOf bio:BiologicalScenario .

ex:Populations a owl:Class ;
    rdfs:subClassOf dul:Collection .

ex:PublicHealthResponseSituation a dul:Situation ;
    dul:hasParticipant ex:PublicHealthMonitor ;
    dul:hasSetting ex:CommunityHealth,
        ex:DiseaseTransmission,
        ex:PreventionMeasures ;
    rdfs:comment "A situation in which a PublicHealthMonitor tracks DiseaseTransmission and applies PreventionMeasures to preserve CommunityHealth." ;
    rdfs:subClassOf bio:BiologicalScenario .

ex:SensoryIntegrationSituation a dul:Situation ;
    dul:hasParticipant ex:SensoryProcessor ;
    dul:hasSetting ex:MultimodalInformation,
        ex:PerceptualIntegration,
        ex:SensoryExperience ;
    rdfs:comment "A situation where a SensoryProcessor integrates MultimodalInformation via PerceptualIntegration to generate SensoryExperience." ;
    rdfs:subClassOf bio:BiologicalScenario .

ex:ServiceDependency a owl:Class ;
    rdfs:subClassOf dul:State .

ex:StressAdaptationSituation a dul:Situation ;
    dul:hasParticipant ex:StressResearcher ;
    dul:hasSetting ex:AdaptationMechanisms,
        ex:RecoveryProcesses,
        ex:StressResponses ;
    rdfs:comment "A situation where a StressResearcher examines StressResponses, AdaptationMechanisms, and RecoveryProcesses." ;
    rdfs:subClassOf bio:BiologicalScenario .

ex:SystemIntegrationSituation a dul:Situation ;
    dul:hasParticipant ex:SystemAnalyst ;
    dul:hasSetting ex:BodySystemIntegration,
        ex:BodySystems,
        ex:OrganFunctions ;
    rdfs:comment "A situation where a SystemAnalyst examines how BodySystems coordinate OrganFunctions toward BodySystemIntegration." ;
    rdfs:subClassOf bio:BiologicalScenario .

ex:TherapeuticCareSituation a dul:Situation ;
    dul:hasParticipant ex:Caregiver,
        ex:Patient ;
    dul:hasSetting ex:RecoveryProgress,
        ex:TreatmentMethods ;
    rdfs:comment "A situation where a Caregiver applies TreatmentMethods to a Patient and monitors RecoveryProgress." ;
    rdfs:subClassOf bio:BiologicalScenario .

ex:VitalSystemRegulationSituation a dul:Situation ;
    dul:hasParticipant ex:PhysiologyMonitor ;
    dul:hasSetting ex:HomeostasisMaintenance,
        ex:RegulatoryFunctions,
        ex:VitalSystems ;
    rdfs:comment "A situation in which a PhysiologyMonitor observes VitalSystems performing RegulatoryFunctions to maintain Homeostasis." ;
    rdfs:subClassOf bio:BiologicalScenario .

ex:WellnessMaintenanceSituation a dul:Situation ;
    dul:hasParticipant ex:HealthMaintainer ;
    dul:hasSetting ex:HealthyBehaviors,
        ex:PreventiveActions,
        ex:WellnessRoutines ;
    rdfs:comment "A situation in which a HealthMaintainer engages in PreventiveActions, HealthyBehaviors, and WellnessRoutines to maintain OptimalWellness." ;
    rdfs:subClassOf bio:BiologicalScenario .

ex:achieves a owl:ObjectProperty ;
    rdfs:domain ex:MovementExecution,
        ex:SystemicCoordination ;
    rdfs:range ex:BodySystemIntegration,
        ex:IntendedActions ;
    rdfs:subPropertyOf dul:executes,
        dul:hasEffect .

ex:achievesPrecisionWith a owl:ObjectProperty ;
    rdfs:domain ex:MovementExecution ;
    rdfs:range ex:MovementPrecision ;
    rdfs:subPropertyOf dul:hasQuality .

ex:activate a owl:ObjectProperty ;
    rdfs:domain ex:StressResponses ;
    rdfs:range ex:AdaptationMechanisms ;
    rdfs:subPropertyOf dul:hasEffect .

ex:addresses a owl:ObjectProperty ;
    rdfs:domain ex:TreatmentMethods ;
    rdfs:range ex:HealthProblems ;
    rdfs:subPropertyOf dul:associatedWith .

ex:affects a owl:ObjectProperty ;
    rdfs:domain ex:EcosystemDynamics,
        ex:EmotionalDistress ;
    rdfs:range ex:EcologicalProductivity,
        ex:PsychologicalWellbeing ;
    rdfs:subPropertyOf dul:hasEffect .

ex:affectsStability a owl:ObjectProperty ;
    rdfs:domain ex:EcosystemDynamics ;
    rdfs:range ex:SystemStability ;
    rdfs:subPropertyOf dul:hasEffect .

ex:aimToMaintain a owl:ObjectProperty ;
    rdfs:domain ex:HealthyBehaviors,
        ex:PreventiveActions ;
    rdfs:range ex:OptimalWellness ;
    rdfs:subPropertyOf dul:hasEffect .

ex:analyzes a owl:ObjectProperty ;
    rdfs:domain ex:ProportionAnalyst ;
    rdfs:range ex:ProportionalRelationships ;
    rdfs:subPropertyOf dul:observes .

ex:appliedTo a owl:ObjectProperty ;
    rdfs:domain ex:TreatmentMethods ;
    rdfs:range ex:Patient ;
    rdfs:subPropertyOf dul:hasParticipant .

ex:applies a owl:ObjectProperty ;
    rdfs:domain ex:Caregiver ;
    rdfs:range ex:TreatmentMethods ;
    rdfs:subPropertyOf dul:executes .

ex:arePartOf a owl:ObjectProperty ;
    rdfs:domain ex:BodyParts ;
    rdfs:range ex:AnatomicalStructures ;
    rdfs:subPropertyOf dul:isPartOf .

ex:assesses a owl:ObjectProperty ;
    rdfs:domain ex:HealthMonitor ;
    rdfs:range ex:SeverityLevels ;
    rdfs:subPropertyOf dul:observes .

ex:avoids a owl:ObjectProperty ;
    rdfs:domain ex:HealthMaintainer ;
    rdfs:range ex:HealthRisks ;
    rdfs:subPropertyOf dul:hasGoal .

ex:benefit a owl:ObjectProperty ;
    rdfs:domain ex:EcosystemServices ;
    rdfs:range ex:HumanCommunities ;
    rdfs:subPropertyOf dul:hasParticipant .

ex:characterize a owl:ObjectProperty ;
    rdfs:domain ex:GrowthPatterns ;
    rdfs:range ex:DevelopmentalPhases ;
    rdfs:subPropertyOf dul:classifies .

ex:characterizedBy a owl:ObjectProperty ;
    rdfs:domain ex:NaturalHabitats ;
    rdfs:range ex:EnvironmentalConditions ;
    rdfs:subPropertyOf dul:hasRegion .

ex:combinedBy a owl:ObjectProperty ;
    rdfs:domain ex:MultimodalInformation ;
    rdfs:range ex:PerceptualIntegration ;
    rdfs:subPropertyOf dul:isSettingFor .

ex:combinesInputFrom a owl:ObjectProperty ;
    rdfs:domain ex:MultimodalInformation ;
    rdfs:range ex:SensoryOrgans ;
    rdfs:subPropertyOf dul:hasComponent .

ex:combinesWith a owl:ObjectProperty ;
    rdfs:domain ex:MuscleActivation ;
    rdfs:range ex:JointMovements ;
    rdfs:subPropertyOf dul:hasComponent .

ex:completes a owl:ObjectProperty ;
    rdfs:domain ex:HomeostasisRestoration ;
    rdfs:range ex:RecoveryProcesses ;
    rdfs:subPropertyOf dul:hasOutcome .

ex:compose a owl:ObjectProperty ;
    rdfs:domain ex:AnatomicalDimensions ;
    rdfs:range ex:BodyProportions ;
    rdfs:subPropertyOf dul:hasComponent .

ex:comprise a owl:ObjectProperty ;
    rdfs:domain ex:BodySystems ;
    rdfs:range ex:FunctionalUnits ;
    rdfs:subPropertyOf dul:hasComponent .

ex:connectLevelsOf a owl:ObjectProperty ;
    rdfs:domain ex:EnergyPathways ;
    rdfs:range ex:EcologicalNetworks ;
    rdfs:subPropertyOf dul:hasComponent .

ex:connectedBy a owl:ObjectProperty ;
    rdfs:domain ex:BodyParts ;
    rdfs:range ex:FunctionalConnections ;
    rdfs:subPropertyOf dul:associatedWith .

ex:contain a owl:ObjectProperty ;
    rdfs:domain ex:EcologicalNetworks ;
    rdfs:range ex:FoodChains ;
    rdfs:subPropertyOf dul:hasPart .

ex:containEnergyPaths a owl:ObjectProperty ;
    rdfs:domain ex:EcologicalNetworks ;
    rdfs:range ex:EnergyPathways ;
    rdfs:subPropertyOf dul:hasComponent .

ex:containedIn a owl:ObjectProperty ;
    rdfs:domain ex:InternalStructures ;
    rdfs:range ex:BodyCavities ;
    rdfs:subPropertyOf dul:isPartOf .

ex:contributeTo a owl:ObjectProperty ;
    rdfs:domain ex:BodyRegions,
        ex:CopingMechanisms ;
    rdfs:range ex:PsychologicalResilience,
        ex:StructuralOrganization ;
    rdfs:subPropertyOf dul:hasComponent,
        dul:hasEffect .

ex:contributesTo a owl:ObjectProperty ;
    rdfs:domain ex:GeneticDiversity ;
    rdfs:range ex:SpeciesRichness ;
    rdfs:subPropertyOf dul:hasComponent .

ex:control a owl:ObjectProperty ;
    rdfs:domain ex:BiologicalClocks,
        ex:PublicHealthInterventions ;
    rdfs:range ex:DiseaseOutbreaks,
        ex:TemporalRegulation ;
    rdfs:subPropertyOf dul:hasEffect,
        dul:hasFunction .

ex:coordinate a owl:ObjectProperty ;
    rdfs:domain ex:SynchronizationMechanisms ;
    rdfs:range ex:CircadianRhythms ;
    rdfs:subPropertyOf dul:hasComponent .

ex:coordinateThrough a owl:ObjectProperty ;
    rdfs:domain ex:VitalSystems ;
    rdfs:range ex:SystemicProcesses ;
    rdfs:subPropertyOf dul:hasProcess .

ex:coordinateVia a owl:ObjectProperty ;
    rdfs:domain ex:OrganFunctions ;
    rdfs:range ex:SystemicCoordination ;
    rdfs:subPropertyOf dul:hasRegion .

ex:copeWith a owl:ObjectProperty ;
    rdfs:domain ex:AdaptiveResponses ;
    rdfs:range ex:EnvironmentalStressors ;
    rdfs:subPropertyOf dul:solves .

ex:creates a owl:ObjectProperty ;
    rdfs:domain ex:PerceptualIntegration ;
    rdfs:range ex:SensoryExperience ;
    rdfs:subPropertyOf dul:hasEffect .

ex:define a owl:ObjectProperty ;
    rdfs:domain ex:SizeRelationships ;
    rdfs:range ex:BodyProportions ;
    rdfs:subPropertyOf dul:hasRegion .


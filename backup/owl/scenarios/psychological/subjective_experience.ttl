ex:BodyEmotions a owl:Class ;
    rdfs:label "BodyEmotions" ;
    rdfs:comment "Emotions primarily experienced through physical sensations" ;
    rdfs:subClassOf <dul:Event> .

ex:BodyRhythms a owl:Class ;
    rdfs:label "BodyRhythms" ;
    rdfs:comment "Natural cyclical patterns in bodily functions" ;
    rdfs:subClassOf <dul:Event> .

ex:ComfortSensations a owl:Class ;
    rdfs:label "ComfortSensations" ;
    rdfs:comment "Pleasant bodily feelings indicating good physical conditions" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:DiscomfortCauses a owl:Class ;
    rdfs:label "DiscomfortCauses" ;
    rdfs:comment "Factors that create unpleasant bodily experiences" ;
    rdfs:subClassOf <dul:Event> .

ex:DiscomfortSignals a owl:Class ;
    rdfs:label "DiscomfortSignals" ;
    rdfs:comment "Unpleasant bodily feelings indicating problematic conditions" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:EmbodiedExperiencer a owl:Class ;
    rdfs:label "EmbodiedExperiencer" ;
    rdfs:comment "Person with conscious awareness of their bodily experience" ;
    rdfs:subClassOf <dul:Agent> .

ex:EmbodiedFeeler a owl:Class ;

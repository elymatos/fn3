@prefix dul: <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#> .
@prefix dul1: <http://www.loa-cnr.it/ontologies/DUL.owl#> .
@prefix emo: <http://example.org/gemini/psychological/emotion#> .
@prefix ex: <http://example.org/needs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix perc: <http://example.org/gemini/psychological/perception#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

emo: owl:imports dul: .

emo:AffectiveContagionContext a dul:Situation ;
    dul:hasParticipant emo:InteractingAgents ;
    dul:hasSetting emo:ContagionProcess,
        emo:ObservedEmotion,
        emo:SharedEmotion .

emo:EmotionRegulationContext a dul:Situation ;
    dul:hasParticipant emo:RegulatingAgent ;
    dul:hasSetting emo:CopingAction,
        emo:RegulatedEmotion,
        emo:RegulationStrategy .

emo:EmotionalExpressionContext a dul:Situation ;
    dul:hasParticipant emo:ObservedAgent ;
    dul:hasSetting emo:EmotionalCue,
        emo:ExpressiveBehavior,
        emo:RecognitionProcess .

emo:EmotionalMemoryContext a dul:Situation ;
    dul:hasSetting emo:AssociatedFeeling,
        emo:EmotionalEvent,
        emo:MemoryAssociation,
        emo:MemoryContext .

emo:MoodFluctuationContext a dul:Situation ;
    dul:hasSetting emo:FluctuationCycle,
        emo:MoodRegulation,
        emo:MoodState,
        emo:TemporalPattern .

emo:activates a owl:ObjectProperty ;
    rdfs:domain emo:AffectiveTrigger ;
    rdfs:range emo:RegulatedEmotion ;
    rdfs:subPropertyOf dul:hasCause .

emo:anchoredIn a owl:ObjectProperty ;
    rdfs:domain emo:MemoryAssociation ;
    rdfs:range emo:MemoryContext ;
    rdfs:subPropertyOf dul:hasSetting .

emo:detects a owl:ObjectProperty ;
    rdfs:domain emo:RecognitionProcess ;
    rdfs:range emo:EmotionalCue ;
    rdfs:subPropertyOf dul:hasObject .

emo:emergesAmong a owl:ObjectProperty ;
    rdfs:domain emo:AffectiveSynchronization ;
    rdfs:range emo:InteractingAgents ;
    rdfs:subPropertyOf dul:hasParticipant .

emo:engagesIn a owl:ObjectProperty ;
    rdfs:domain emo:RegulatingAgent ;
    rdfs:range emo:RegulationStrategy ;
    rdfs:subPropertyOf dul:hasTask .

emo:experiencedIn a owl:ObjectProperty ;
    rdfs:domain emo:SharedEmotion ;
    rdfs:range emo:AffectiveSynchronization ;
    rdfs:subPropertyOf dul:hasSetting .

emo:expresses a owl:ObjectProperty ;
    rdfs:domain emo:ExpressiveBehavior ;
    rdfs:range emo:EmotionState ;
    rdfs:subPropertyOf dul:hasQuality .

emo:fluctuatesWithin a owl:ObjectProperty ;
    rdfs:domain emo:MoodState ;
    rdfs:range emo:FluctuationCycle ;
    rdfs:subPropertyOf dul:hasSetting .

emo:induces a owl:ObjectProperty ;
    rdfs:domain emo:ContagionProcess ;
    rdfs:range emo:SharedEmotion ;
    rdfs:subPropertyOf dul:hasEffect .

emo:infers a owl:ObjectProperty ;
    rdfs:domain emo:RecognitionProcess ;
    rdfs:range emo:EmotionState ;
    rdfs:subPropertyOf dul:hasInterpretation .

emo:influences a owl:ObjectProperty ;
    rdfs:domain emo:EnvironmentalCue ;
    rdfs:range emo:MoodState ;
    rdfs:subPropertyOf dul:hasEffect .

emo:linkedTo a owl:ObjectProperty ;
    rdfs:domain emo:MemoryAssociation ;
    rdfs:range emo:AssociatedFeeling ;
    rdfs:subPropertyOf dul:hasQuality .

emo:modifies a owl:ObjectProperty ;
    rdfs:domain emo:CopingAction ;
    rdfs:range emo:RegulatedEmotion ;
    rdfs:subPropertyOf dul:hasEffect .

emo:patternedBy a owl:ObjectProperty ;
    rdfs:domain emo:MoodState ;
    rdfs:range emo:TemporalPattern ;
    rdfs:subPropertyOf dul:hasQuality .

emo:performs a owl:ObjectProperty ;
    rdfs:domain emo:ObservedAgent ;
    rdfs:range emo:ExpressiveBehavior ;
    rdfs:subPropertyOf dul:hasEvent .

emo:resultsIn a owl:ObjectProperty ;
    rdfs:domain emo:RegulationStrategy ;
    rdfs:range emo:CopingAction ;
    rdfs:subPropertyOf dul:hasEffect .

emo:retrieves a owl:ObjectProperty ;
    rdfs:domain emo:EmotionalRecall ;
    rdfs:range emo:MemoryAssociation ;
    rdfs:subPropertyOf dul:hasComponent .

emo:stabilizes a owl:ObjectProperty ;
    rdfs:domain emo:MoodRegulation ;
    rdfs:range emo:MoodState ;
    rdfs:subPropertyOf dul:hasEffect .

emo:storedAs a owl:ObjectProperty ;
    rdfs:domain emo:EmotionalEvent ;
    rdfs:range emo:MemoryAssociation ;
    rdfs:subPropertyOf dul:hasInterpretation .

emo:transferredThrough a owl:ObjectProperty ;
    rdfs:domain emo:ObservedEmotion ;
    rdfs:range emo:ContagionProcess ;
    rdfs:subPropertyOf dul:hasEvent .

perc: owl:imports dul: .

perc:AttentionalCapacity a owl:Class ;
    rdfs:subClassOf dul:Quality .

perc:AttentionalPerceptionContext a dul:Situation ;
    dul:hasParticipant perc:AttentionController ;
    dul:hasSetting perc:AttentionalFiltering,
        perc:FocusControl,
        perc:SelectiveAttention .

perc:DiscriminationAbilities a owl:Class ;
    rdfs:subClassOf dul:Quality .

perc:PerceptualAccuracy a owl:Class ;
    rdfs:subClassOf dul:Quality .

perc:PerceptualCoherence a owl:Class ;
    rdfs:subClassOf dul:Quality .

perc:PerceptualDistortions a owl:Class ;
    rdfs:subClassOf dul:Process .

perc:PerceptualIllusionContext a dul:Situation ;
    dul:hasParticipant perc:PerceptualExplorer ;
    dul:hasSetting perc:CognitiveInfluences,
        perc:PerceptualIllusions,
        perc:SensoryEvidence .

perc:PerceptualOrganizationContext a dul:Situation ;
    dul:hasParticipant perc:Perceiver ;
    dul:hasSetting perc:PerceptualObjects,
        perc:PerceptualProcessing,
        perc:SensoryInput .

perc:PerceptualSensitivityContext a dul:Situation ;
    dul:hasParticipant perc:SensoryMonitor ;
    dul:hasSetting perc:SensitivityLevels,
        perc:SensoryAdaptation,
        perc:SensoryModalities .

perc:SensoryAwareness a owl:Class ;
    rdfs:subClassOf dul:State .

perc:SensoryChannels a owl:Class ;
    rdfs:subClassOf dul:Object .

perc:SensoryIntegrationContext a dul:Situation ;
    dul:hasParticipant perc:SensoryIntegrator ;
    dul:hasSetting perc:CrossModalProcessing,
        perc:IntegratedPerceptions,
        perc:UnifiedSensoryExperience .

perc:SensoryStimuli a owl:Class ;
    rdfs:subClassOf dul:Object .

perc:affects a owl:ObjectProperty ;
    rdfs:domain perc:SensoryAdaptation ;
    rdfs:range perc:PerceptualChanges ;
    rdfs:subPropertyOf dul:hasEffect .

perc:combines a owl:ObjectProperty ;
    rdfs:domain perc:CrossModalProcessing ;
    rdfs:range perc:MultiSensoryInputs ;
    rdfs:subPropertyOf dul:hasParticipant .

perc:deviateFrom a owl:ObjectProperty ;
    rdfs:domain perc:SensoryMisinterpretations ;
    rdfs:range perc:ActualReality ;
    rdfs:subPropertyOf dul:hasReference .

perc:enables a owl:ObjectProperty ;
    rdfs:domain perc:SensoryBinding ;
    rdfs:range perc:MultimodalIntegration ;
    rdfs:subPropertyOf dul:hasComponent .

perc:exhibit a owl:ObjectProperty ;
    rdfs:domain perc:SensoryModalities ;
    rdfs:range perc:SensitivityLevels ;
    rdfs:subPropertyOf dul:hasQuality .

perc:generates a owl:ObjectProperty ;
    rdfs:domain perc:CrossModalProcessing ;
    rdfs:range perc:IntegratedPerceptions ;
    rdfs:subPropertyOf dul:hasOutcome .

perc:guidedBy a owl:ObjectProperty ;
    rdfs:domain perc:PerceptualSelection ;
    rdfs:range perc:AttentionalSustainment ;
    rdfs:subPropertyOf dul:hasSetting .

perc:have a owl:ObjectProperty ;
    rdfs:domain perc:SensoryModalities ;
    rdfs:range perc:PerceptualThresholds ;
    rdfs:subPropertyOf dul:hasQuality .

perc:highlights a owl:ObjectProperty ;
    rdfs:domain perc:SelectiveAttention ;
    rdfs:range perc:RelevantStimuli ;
    rdfs:subPropertyOf dul:hasParticipant .

perc:interfereWith a owl:ObjectProperty ;
    rdfs:domain perc:DistractingElements ;
    rdfs:range perc:FocusControl ;
    rdfs:subPropertyOf dul:hasEffect .

perc:involve a owl:ObjectProperty ;
    rdfs:domain perc:PerceptualIllusions ;
    rdfs:range perc:SensoryMisinterpretations ;
    rdfs:subPropertyOf dul:hasComponent .

perc:leadsTo a owl:ObjectProperty ;
    rdfs:domain perc:SensoryEvidence ;
    rdfs:range perc:InterpretationErrors ;
    rdfs:subPropertyOf dul:hasEffect .

perc:limit a owl:ObjectProperty ;
    rdfs:domain perc:SensoryModalities ;
    rdfs:range perc:DetectionLimits ;
    rdfs:subPropertyOf dul:hasConstraint .

perc:manages a owl:ObjectProperty ;
    rdfs:domain perc:AttentionController ;
    rdfs:range perc:FocusControl ;
    rdfs:subPropertyOf dul:hasTask .

perc:modulatedBy a owl:ObjectProperty ;
    rdfs:domain perc:PerceptualProcessing ;
    rdfs:range perc:AttentionalFocus ;
    rdfs:subPropertyOf dul:hasParticipant .

perc:organizes a owl:ObjectProperty ;
    rdfs:domain perc:PerceptualProcessing ;
    rdfs:range perc:SensoryPatterns ;
    rdfs:subPropertyOf dul:hasParticipant .

perc:produces a owl:ObjectProperty ;
    rdfs:domain perc:PerceptualProcessing ;
    rdfs:range perc:PerceptualObjects ;
    rdfs:subPropertyOf dul:hasOutcome .

perc:receivesInputFrom a owl:ObjectProperty ;
    rdfs:domain perc:PerceptualProcessing ;
    rdfs:range perc:SensoryInput ;
    rdfs:subPropertyOf dul:hasParticipant .

perc:refines a owl:ObjectProperty ;
    rdfs:domain perc:PerceptualFiltering ;
    rdfs:range perc:OrganizedExperience ;
    rdfs:subPropertyOf dul:hasEffect .

perc:resolve a owl:ObjectProperty ;
    rdfs:domain perc:ModalityInteractions ;
    rdfs:range perc:SensoryConflicts ;
    rdfs:subPropertyOf dul:hasTask .

perc:resultIn a owl:ObjectProperty ;
    rdfs:domain perc:IntegratedPerceptions ;
    rdfs:range perc:UnifiedSensoryExperience ;
    rdfs:subPropertyOf dul:hasSetting .

perc:shapedBy a owl:ObjectProperty ;
    rdfs:domain perc:PerceptualMechanisms ;
    rdfs:range perc:CognitiveInfluences ;
    rdfs:subPropertyOf dul:hasParticipant .

perc:suppresses a owl:ObjectProperty ;
    rdfs:domain perc:AttentionalFiltering ;
    rdfs:range perc:IrrelevantInformation ;
    rdfs:subPropertyOf dul:hasParticipant .

perc:tracks a owl:ObjectProperty ;
    rdfs:domain perc:SensoryMonitor ;
    rdfs:range perc:SensoryModalities ;
    rdfs:subPropertyOf dul:hasParticipant .

ex:AccomplishmentPursuitToRecognition a owl:ObjectProperty ;
    rdfs:comment "seeking" ;
    rdfs:domain ex:AccomplishmentPursuit ;
    rdfs:range ex:Recognition ;
    rdfs:subPropertyOf <dul:hasParticipant> .

ex:AccomplishmentPursuitToSelfActualization a owl:ObjectProperty ;
    rdfs:comment "successful pursuit" ;
    rdfs:domain ex:AccomplishmentPursuit ;
    rdfs:range ex:SelfActualization ;
    rdfs:subPropertyOf <dul:hasOutcome> .

ex:AccomplishmentPursuitToSkillDevelopment a owl:ObjectProperty ;
    rdfs:comment "involves" ;
    rdfs:domain ex:AccomplishmentPursuit ;
    rdfs:range ex:SkillDevelopment ;
    rdfs:subPropertyOf <dul:includesEvent> .

ex:AchievementMotivationToCompetencyNeeds a owl:ObjectProperty ;
    rdfs:comment "emerges from" ;
    rdfs:domain ex:AchievementMotivation ;
    rdfs:range ex:CompetencyNeeds ;
    rdfs:subPropertyOf <dul:isCausedBy> .

ex:AchieverToPerformanceImprovement a owl:ObjectProperty ;
    rdfs:comment "engages in" ;
    rdfs:domain ex:Achiever ;
    rdfs:range ex:PerformanceImprovement ;
    rdfs:subPropertyOf <dul:performsTask> .

ex:AchieverToPsychologicalGoals a owl:ObjectProperty ;
    rdfs:comment "pursues" ;
    rdfs:domain ex:Achiever ;
    rdfs:range ex:PsychologicalGoals ;
    rdfs:subPropertyOf <dul:hasTask> .

ex:AchieverToSkillDevelopment a owl:ObjectProperty ;
    rdfs:comment "engages in" ;
    rdfs:domain ex:Achiever ;
    rdfs:range ex:SkillDevelopment ;
    rdfs:subPropertyOf <dul:performsTask> .

ex:AmbientAwarenessToAtmosphericQualities a owl:ObjectProperty ;
    rdfs:comment "detects" ;
    rdfs:domain ex:AmbientAwareness ;
    rdfs:range ex:AtmosphericQualities ;
    rdfs:subPropertyOf <dul:detects> .

ex:AmbientAwarenessToEnvironmentalMoods a owl:ObjectProperty ;
    rdfs:comment "detects" ;
    rdfs:domain ex:AmbientAwareness ;
    rdfs:range ex:EnvironmentalMoods ;
    rdfs:subPropertyOf <dul:detects> .

ex:ApproachAvoidanceConflictsToMultipleMotivations a owl:ObjectProperty ;
    rdfs:comment "arise from" ;
    rdfs:domain ex:ApproachAvoidanceConflicts ;
    rdfs:range ex:MultipleMotivations ;
    rdfs:subPropertyOf <dul:resultsFrom> .

ex:AtmosphericQualitiesToEnvironmentalPresence a owl:ObjectProperty ;
    rdfs:comment "influence" ;
    rdfs:domain ex:AtmosphericQualities ;
    rdfs:range ex:EnvironmentalPresence ;
    rdfs:subPropertyOf <dul:influences> .

ex:AutonomousAgentToExternalPressures a owl:ObjectProperty ;
    rdfs:comment "resists" ;
    rdfs:domain ex:AutonomousAgent ;
    rdfs:range ex:ExternalPressures ;
    rdfs:subPropertyOf <dul:resists> .

ex:AutonomousAgentToIntrinsicallyMotivatedBehavior a owl:ObjectProperty ;
    rdfs:comment "engages in" ;
    rdfs:domain ex:AutonomousAgent ;
    rdfs:range ex:IntrinsicallyMotivatedBehavior ;
    rdfs:subPropertyOf <dul:performsTask> .

ex:BasicNeedsToBiologicalDrives a owl:ObjectProperty ;
    rdfs:comment "generate" ;
    rdfs:domain ex:BasicNeeds ;
    rdfs:range ex:BiologicalDrives ;
    rdfs:subPropertyOf <dul:hasQuality> .

ex:BelongingNeedsToSocialConnections a owl:ObjectProperty ;
    rdfs:comment "motivate" ;
    rdfs:domain ex:BelongingNeeds ;
    rdfs:range ex:SocialConnections ;
    rdfs:subPropertyOf <dul:triggers> .

ex:BiologicalDrivesToMotivationalStates a owl:ObjectProperty ;
    rdfs:comment "create" ;
    rdfs:domain ex:BiologicalDrives ;
    rdfs:range ex:MotivationalStates ;
    rdfs:subPropertyOf <dul:hasConstituent> .

ex:BodilyComfortToComfortSensations a owl:ObjectProperty ;

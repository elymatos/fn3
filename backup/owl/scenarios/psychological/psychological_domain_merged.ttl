    rdfs:domain ex:ComfortSeeking ;
    rdfs:range ex:BodilyComfort ;
    rdfs:subPropertyOf <dul:aimsTo> .

ex:CompetingDrivesToConflictingGoals a owl:ObjectProperty ;
    rdfs:comment "create" ;
    rdfs:domain ex:CompetingDrives ;
    rdfs:range ex:ConflictingGoals ;
    rdfs:subPropertyOf <dul:causes> .

ex:ConflictResolutionToMotivationalCompromise a owl:ObjectProperty ;

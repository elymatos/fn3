ex:EnvironmentalPerceiverToEnvironmentalPresence a owl:ObjectProperty ;
    rdfs:comment "experiences" ;
    rdfs:domain ex:EnvironmentalPerceiver ;
    rdfs:range ex:EnvironmentalPresence ;

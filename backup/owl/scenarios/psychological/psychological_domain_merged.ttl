    rdfs:range ex:TimePerception ;
    rdfs:subPropertyOf <dul:influences> .

ex:BodySchemasToPosturalInformation a owl:ObjectProperty ;
    rdfs:comment "organize" ;
    rdfs:domain ex:BodySchemas ;
    rdfs:range ex:PosturalInformation ;
    rdfs:subPropertyOf <dul:organizes> .

ex:BodySchemasToSpatialEmbodiment a owl:ObjectProperty ;
    rdfs:comment "into" ;
    rdfs:domain ex:BodySchemas ;
    rdfs:range ex:SpatialEmbodiment ;
    rdfs:subPropertyOf <dul:produces> .

ex:BodyTimeAwarenessToTemporalEmbodiment a owl:ObjectProperty ;
    rdfs:comment "enables" ;
    rdfs:domain ex:BodyTimeAwareness ;
    rdfs:range ex:TemporalEmbodiment ;
    rdfs:subPropertyOf <dul:enables> .

ex:BodyWellbeingToPhysicalSatisfaction a owl:ObjectProperty ;

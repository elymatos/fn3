    rdfs:range ex:PhysicalSatisfaction ;
    rdfs:subPropertyOf <dul:contributesTo> .

ex:ComfortFactorsToBodilyComfort a owl:ObjectProperty ;
    rdfs:comment "promote" ;
    rdfs:domain ex:ComfortFactors ;
    rdfs:range ex:BodilyComfort ;
    rdfs:subPropertyOf <dul:promotes> .

ex:ComfortFactorsToBodyWellbeing a owl:ObjectProperty ;
    rdfs:comment "promote" ;
    rdfs:domain ex:ComfortFactors ;
    rdfs:range ex:BodyWellbeing ;
    rdfs:subPropertyOf <dul:promotes> .

ex:ComfortSeekerToBodilyComfort a owl:ObjectProperty ;
    rdfs:comment "experiences" ;
    rdfs:domain ex:ComfortSeeker ;
    rdfs:range ex:BodilyComfort ;
    rdfs:subPropertyOf <dul:hasTask> .

ex:ComfortSeekerToComfortSeeking a owl:ObjectProperty ;
    rdfs:comment "engages in" ;
    rdfs:domain ex:ComfortSeeker ;
    rdfs:range ex:ComfortSeeking ;
    rdfs:subPropertyOf <dul:engagesIn> .

ex:ComfortSeekerToDiscomfortAvoidance a owl:ObjectProperty ;

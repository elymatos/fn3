@prefix att: <http://example.org/gemini/cognitive/attention#> .
@prefix bel: <http://example.org/gemini/cognitive/belief#> .
@prefix dec: <http://example.org/gemini/cognitive/decision#> .
@prefix dul: <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#> .
@prefix eva: <http://example.org/gemini/cognitive/evaluation#> .
@prefix int: <http://example.org/gemini/cognitive/intention#> .
@prefix mem: <http://example.org/gemini/cognitive/memory#> .
@prefix ns1: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rsn: <http://example.org/gemini/cognitive/reasoning#> .

att: ns1:imports dul: .

att:AttentionalLimitations a ns1:Class ;
    rdfs:subClassOf dul:Quality .

att:ConsciousMonitoringSituation a dul:Situation ;
    dul:hasParticipant att:ConsciousObserver ;
    dul:hasSetting att:AwarenessStates,
        att:MetaAwareness,
        att:SelfReflection ;
    rdfs:comment "Situation where a ConsciousObserver monitors AwarenessStates and engages in MetaAwareness and SelfReflection." .

att:DistractiveThoughts a ns1:Class ;
    rdfs:subClassOf dul:Object .

att:MindfulnessSituation a dul:Situation ;
    dul:hasParticipant att:MindfulPractitioner ;
    dul:hasSetting att:AttentionalTraining,
        att:ClarityOfMind,
        att:MindfulnessExercises ;
    rdfs:comment "Situation where a MindfulPractitioner engages in MindfulnessExercises to develop AttentionalTraining and attain ClarityOfMind." .

att:MultitaskingSituation a dul:Situation ;
    dul:hasParticipant att:Multitasker ;
    dul:hasSetting att:ConcurrentTasks,
        att:DividedAttention,
        att:MultitaskingStrategies ;
    rdfs:comment "Situation where a Multitasker uses DividedAttention across ConcurrentTasks with specific MultitaskingStrategies." .

att:PresentMomentAwareness a ns1:Class ;
    rdfs:subClassOf dul:State .

att:SelectiveAttentionSituation a dul:Situation ;
    dul:hasParticipant att:AttentionalController ;
    dul:hasSetting att:AttentionalStrategies,
        att:RelevantStimuli,
        att:SelectiveAttention ;
    rdfs:comment "Situation where an AttentionalController directs SelectiveAttention to RelevantStimuli using AttentionalStrategies." .

att:TargetEvents a ns1:Class ;
    rdfs:subClassOf dul:Object .

att:VigilanceSituation a dul:Situation ;
    dul:hasParticipant att:VigilanceOperator ;
    dul:hasSetting att:AlertMonitoring,
        att:CriticalSignals,
        att:ResponseReadiness ;
    rdfs:comment "Situation where a VigilanceOperator performs AlertMonitoring to detect CriticalSignals and maintain ResponseReadiness." .

att:affects a ns1:ObjectProperty ;
    rdfs:domain att:TaskSwitching ;
    rdfs:range att:PerformanceTradeoffs ;
    rdfs:subPropertyOf <http://example.org/gemini/cognitive/common#affects>,
        dul:hasEffect .

att:allocatesTo a ns1:ObjectProperty ;
    rdfs:domain att:DividedAttention ;
    rdfs:range att:MultipleTargets ;
    rdfs:subPropertyOf dul:hasParticipant .

att:detects a ns1:ObjectProperty ;
    rdfs:domain att:AlertMonitoring ;
    rdfs:range att:CriticalSignals ;
    rdfs:subPropertyOf <http://example.org/gemini/cognitive/common#detects>,
        dul:hasParticipant .

att:develop a ns1:ObjectProperty ;
    rdfs:domain att:MindfulnessExercises ;
    rdfs:range att:AttentionalTraining ;
    rdfs:subPropertyOf dul:realizes .

att:directsAttentionTo a ns1:ObjectProperty ;
    rdfs:domain att:AttentionalController ;
    rdfs:range att:RelevantStimuli ;
    rdfs:subPropertyOf dul:directlyFollows .

att:distributesOver a ns1:ObjectProperty ;
    rdfs:domain att:DividedAttention ;
    rdfs:range att:ConcurrentTasks ;
    rdfs:subPropertyOf dul:hasRegion .

att:enables a ns1:ObjectProperty ;
    rdfs:domain att:MetaAwareness ;
    rdfs:range att:SelfReflection ;
    rdfs:subPropertyOf dul:hasFunction .

att:engagesIn a ns1:ObjectProperty ;
    rdfs:domain att:MindfulPractitioner,
        att:Multitasker ;
    rdfs:range att:DividedAttention,
        att:MindfulnessExercises ;
    rdfs:subPropertyOf <http://example.org/gemini/cognitive/common#engagesIn>,
        dul:performs .

att:enhances a ns1:ObjectProperty ;
    rdfs:domain att:AttentionalTraining,
        att:SelfReflection ;
    rdfs:range att:ConsciousnessLevels,
        att:SustainedAwareness ;
    rdfs:subPropertyOf dul:hasEffect .

att:experiences a ns1:ObjectProperty ;
    rdfs:domain att:ConsciousObserver ;
    rdfs:range att:AwarenessStates ;
    rdfs:subPropertyOf dul:hasParticipant .

att:filtersOut a ns1:ObjectProperty ;
    rdfs:domain att:AttentionalController ;
    rdfs:range att:DistractingElements ;
    rdfs:subPropertyOf dul:hasFunction .

att:influence a ns1:ObjectProperty ;
    rdfs:domain att:AttentionalModes ;
    rdfs:range att:AwarenessStates ;
    rdfs:subPropertyOf dul:hasQuality .

att:involves a ns1:ObjectProperty ;
    rdfs:domain att:AlertMonitoring,
        att:ConsciousMonitoring ;
    rdfs:range att:CognitiveProcesses,
        att:MonitoringTasks ;
    rdfs:subPropertyOf <http://example.org/gemini/cognitive/common#involves>,
        dul:hasParticipant .

att:leadsTo a ns1:ObjectProperty ;
    rdfs:domain att:SelectiveAttention,
        att:VigilanceDecrement ;
    rdfs:range att:AttentionalFatigue,
        att:ConcentrationStates ;
    rdfs:subPropertyOf dul:hasEffect,
        dul:hasOutcome .

att:maintain a ns1:ObjectProperty ;
    rdfs:domain att:AlertnessStrategies ;
    rdfs:range att:ResponseReadiness ;
    rdfs:subPropertyOf dul:hasGoal .

att:modulates a ns1:ObjectProperty ;
    rdfs:domain att:AttentionalCompetition ;
    rdfs:range att:FocusControl ;
    rdfs:subPropertyOf dul:hasCause .

att:monitors a ns1:ObjectProperty ;
    rdfs:domain att:ConsciousObserver ;
    rdfs:range att:MentalStates ;
    rdfs:subPropertyOf dul:observes .

att:optimize a ns1:ObjectProperty ;
    rdfs:domain att:MultitaskingStrategies ;
    rdfs:range att:CognitiveEfficiency ;
    rdfs:subPropertyOf dul:hasGoal .

att:performs a ns1:ObjectProperty ;
    rdfs:domain att:VigilanceOperator ;
    rdfs:range att:AlertMonitoring ;
    rdfs:subPropertyOf dul:performs .

att:reduces a ns1:ObjectProperty ;
    rdfs:domain att:AttentionalTraining ;
    rdfs:range att:MindWandering ;
    rdfs:subPropertyOf dul:hasEffect .

att:resultsFrom a ns1:ObjectProperty ;
    rdfs:domain att:ClarityOfMind,
        att:MindfulPresence,
        att:OptimalFocus ;
    rdfs:range att:FocusControl,
        att:MindfulPresence,
        att:NonJudgmentalAttention ;
    rdfs:subPropertyOf dul:hasEffect,
        dul:hasOutcome,
        dul:hasQuality .

att:supports a ns1:ObjectProperty ;
    rdfs:domain att:SustainedVigilance ;
    rdfs:range att:DetectionAccuracy ;
    rdfs:subPropertyOf dul:hasOutcome .

att:uses a ns1:ObjectProperty ;
    rdfs:domain att:SelectiveAttention ;
    rdfs:range att:AttentionalStrategies ;
    rdfs:subPropertyOf dul:hasParticipant .

att:utilizes a ns1:ObjectProperty ;
    rdfs:domain att:DividedAttention ;
    rdfs:range att:AttentionalResources ;
    rdfs:subPropertyOf dul:hasParticipant .

bel: ns1:imports dul: .

bel:AssumptionManagementSituation a dul:Situation ;
    dul:hasParticipant bel:AssumptionManager ;
    dul:hasSetting bel:AssumptionTracking,
        bel:CoherenceAssessment,
        bel:LogicalConsistency .

bel:BeliefConflictSituation a dul:Situation ;
    dul:hasParticipant bel:EpistemicNegotiator ;
    dul:hasSetting bel:BeliefIntegration,
        bel:BeliefResolution,
        bel:EpistemicDialogue .

bel:BeliefFormationSituation a dul:Situation ;
    dul:hasParticipant bel:BeliefAgent ;
    dul:hasSetting bel:BeliefFormation,
        bel:EpistemicSupport,
        bel:JustificationProcesses .

bel:CertaintyEvaluationSituation a dul:Situation ;
    dul:hasParticipant bel:CertaintyEvaluator ;
    dul:hasSetting bel:BeliefStability,
        bel:CertaintyAssessment,
        bel:DoubtRecognition .

bel:KnowledgeRevisionSituation a dul:Situation ;
    dul:hasParticipant bel:KnowledgeSeeker ;
    dul:hasSetting bel:CognitiveReorganization,
        bel:ContradictoryEvidence,
        bel:KnowledgeAcquisition .

bel:benefitsFrom a ns1:ObjectProperty ;
    rdfs:domain bel:BeliefResolution ;
    rdfs:range bel:ConsensusStrategies ;
    rdfs:subPropertyOf dul:hasParticipant .

bel:conducts a ns1:ObjectProperty ;
    rdfs:domain bel:CertaintyEvaluator ;
    rdfs:range bel:CertaintyAssessment ;
    rdfs:subPropertyOf dul:performs .

bel:engagesIn a ns1:ObjectProperty ;
    rdfs:domain bel:KnowledgeSeeker ;
    rdfs:range bel:KnowledgeAcquisition ;
    rdfs:subPropertyOf <http://example.org/gemini/cognitive/common#engagesIn>,
        dul:performs .

bel:evaluate a ns1:ObjectProperty ;
    rdfs:domain bel:ConfidenceJudgments ;
    rdfs:range bel:BeliefStability ;
    rdfs:subPropertyOf dul:hasEffect .

bel:evaluates a ns1:ObjectProperty ;
    rdfs:domain bel:CoherenceAssessment ;
    rdfs:range bel:CognitiveAssumptions ;
    rdfs:subPropertyOf dul:hasSetting .

bel:identifies a ns1:ObjectProperty ;
    rdfs:domain bel:AssumptionTracking ;
    rdfs:range bel:ImplicitAssumptions ;
    rdfs:subPropertyOf dul:hasParticipant .

bel:includes a ns1:ObjectProperty ;
    rdfs:domain bel:CertaintyAssessment ;
    rdfs:range bel:DoubtRecognition ;
    rdfs:subPropertyOf dul:hasPart .

bel:informs a ns1:ObjectProperty ;
    rdfs:domain bel:EvidenceEvaluation ;
    rdfs:range bel:JustificationProcesses ;
    rdfs:subPropertyOf dul:hasCause .

bel:initiates a ns1:ObjectProperty ;
    rdfs:domain bel:BeliefAgent ;
    rdfs:range bel:BeliefFormation ;
    rdfs:subPropertyOf dul:performs .

bel:leadTo a ns1:ObjectProperty ;
    rdfs:domain bel:ConsensusStrategies ;
    rdfs:range bel:BeliefIntegration ;
    rdfs:subPropertyOf dul:hasOutcome .

bel:leadsTo a ns1:ObjectProperty ;
    rdfs:domain bel:BeliefFormation ;
    rdfs:range bel:BeliefStates ;
    rdfs:subPropertyOf dul:hasOutcome .

bel:monitors a ns1:ObjectProperty ;
    rdfs:domain bel:AssumptionManager ;
    rdfs:range bel:AssumptionTracking ;
    rdfs:subPropertyOf dul:performs .

bel:produces a ns1:ObjectProperty ;
    rdfs:domain bel:CognitiveReorganization ;
    rdfs:range bel:LearningOutcomes ;
    rdfs:subPropertyOf dul:hasOutput .

bel:requires a ns1:ObjectProperty ;
    rdfs:domain bel:KnowledgeRevision ;
    rdfs:range bel:CognitiveReorganization ;
    rdfs:subPropertyOf dul:hasParticipant .

bel:resolves a ns1:ObjectProperty ;
    rdfs:domain bel:EpistemicNegotiator ;
    rdfs:range bel:ConflictingBeliefs ;
    rdfs:subPropertyOf dul:performs .

bel:resultsFrom a ns1:ObjectProperty ;
    rdfs:domain bel:KnowledgeRevision ;
    rdfs:range bel:ContradictoryEvidence ;
    rdfs:subPropertyOf dul:hasCause .

bel:reveals a ns1:ObjectProperty ;
    rdfs:domain bel:DoubtRecognition ;
    rdfs:range bel:EpistemicUncertainty ;
    rdfs:subPropertyOf dul:hasOutcome .

bel:shouldSatisfy a ns1:ObjectProperty ;
    rdfs:domain bel:CognitiveAssumptions ;
    rdfs:range bel:LogicalConsistency ;
    rdfs:subPropertyOf dul:hasQuality .

bel:support a ns1:ObjectProperty ;
    rdfs:domain bel:JustificationProcesses ;
    rdfs:range bel:BeliefFormation ;
    rdfs:subPropertyOf dul:hasFunction .

bel:supportedBy a ns1:ObjectProperty ;
    rdfs:domain bel:BeliefStates ;
    rdfs:range bel:EpistemicSupport ;
    rdfs:subPropertyOf dul:hasSetting .

bel:uses a ns1:ObjectProperty ;
    rdfs:domain bel:BeliefResolution,
        bel:KnowledgeAcquisition ;
    rdfs:range bel:ConceptualFrameworks,
        bel:EpistemicDialogue ;
    rdfs:subPropertyOf dul:hasParticipant .

dec: ns1:imports dul: .

dec:DeliberationSituation a dul:Situation ;
    dul:hasParticipant dec:Deliberator ;
    dul:hasSetting dec:CostBenefitAnalysis,
        dec:DecisionMaking,
        dec:TradeOffResolution .

dec:ExecutionMonitoringSituation a dul:Situation ;
    dul:hasParticipant dec:ActionExecutor ;
    dul:hasSetting dec:ActionImplementation,
        dec:FeedbackIntegration,
        dec:PerformanceEvaluation .

dec:GoalFormulationSituation a dul:Situation ;
    dul:hasParticipant dec:DecisionAgent ;
    dul:hasSetting dec:GoalFormulation,
        dec:GoalHierarchy,
        dec:ValueAssessment .

dec:PlanningSituation a dul:Situation ;
    dul:hasParticipant dec:Planner ;
    dul:hasSetting dec:ContingencyPlans,
        dec:OutcomeAnticipation,
        dec:PlanningProcesses .

dec:RiskEvaluationSituation a dul:Situation ;
    dul:hasParticipant dec:RiskEvaluator ;
    dul:hasSetting dec:MitigationStrategies,
        dec:ProbabilityJudgments,
        dec:RiskAssessment .

dec:TemporalReasoning a ns1:Class ;
    rdfs:subClassOf dul:Process .

dec:considers a ns1:ObjectProperty ;
    rdfs:domain dec:PlanningProcesses ;
    rdfs:range dec:FutureScenarios ;
    rdfs:subPropertyOf dul:hasSetting .

dec:engagesIn a ns1:ObjectProperty ;
    rdfs:domain dec:Deliberator ;
    rdfs:range dec:DecisionMaking ;
    rdfs:subPropertyOf <http://example.org/gemini/cognitive/common#engagesIn>,
        dul:performs .

dec:evaluates a ns1:ObjectProperty ;
    rdfs:domain dec:DecisionMaking ;
    rdfs:range dec:AlternativeOptions ;
    rdfs:subPropertyOf dul:hasParticipant .

dec:executes a ns1:ObjectProperty ;
    rdfs:domain dec:Planner ;
    rdfs:range dec:PlanningProcesses ;
    rdfs:subPropertyOf dul:performs .

dec:feeds a ns1:ObjectProperty ;
    rdfs:domain dec:CostBenefitAnalysis ;
    rdfs:range dec:TradeOffResolution ;
    rdfs:subPropertyOf dul:hasCause .

dec:formulates a ns1:ObjectProperty ;
    rdfs:domain dec:DecisionAgent ;
    rdfs:range dec:GoalFormulation ;
    rdfs:subPropertyOf dul:performs .

dec:guides a ns1:ObjectProperty ;
    rdfs:domain dec:OutcomeAnticipation ;
    rdfs:range dec:PlanningProcesses ;
    rdfs:subPropertyOf dul:hasFunction .

dec:includes a ns1:ObjectProperty ;
    rdfs:domain dec:PlanningProcesses ;
    rdfs:range dec:ActionSequences ;
    rdfs:subPropertyOf dul:hasPart .

dec:inform a ns1:ObjectProperty ;
    rdfs:domain dec:ProbabilityJudgments ;
    rdfs:range dec:DecisionConfidence ;
    rdfs:subPropertyOf dul:hasEffect .

dec:informs a ns1:ObjectProperty ;
    rdfs:domain dec:FeedbackIntegration ;
    rdfs:range dec:AdjustmentActions ;
    rdfs:subPropertyOf dul:hasCause .

dec:initiates a ns1:ObjectProperty ;
    rdfs:domain dec:ActionExecutor ;
    rdfs:range dec:ActionImplementation ;
    rdfs:subPropertyOf dul:performs .

dec:involves a ns1:ObjectProperty ;
    rdfs:domain dec:RiskAssessment ;
    rdfs:range dec:UncertaintyFactors ;
    rdfs:subPropertyOf <http://example.org/gemini/cognitive/common#involves>,
        dul:hasSetting .

dec:monitors a ns1:ObjectProperty ;
    rdfs:domain dec:PerformanceEvaluation ;
    rdfs:range dec:ActionImplementation ;
    rdfs:subPropertyOf dul:observes .

dec:organizes a ns1:ObjectProperty ;
    rdfs:domain dec:GoalHierarchy ;
    rdfs:range dec:GoalStates ;
    rdfs:subPropertyOf dul:hasPart .

dec:performs a ns1:ObjectProperty ;
    rdfs:domain dec:RiskEvaluator ;
    rdfs:range dec:RiskAssessment ;
    rdfs:subPropertyOf dul:performs .

dec:reduce a ns1:ObjectProperty ;
    rdfs:domain dec:MitigationStrategies ;
    rdfs:range dec:RiskSensitivity ;
    rdfs:subPropertyOf dul:hasGoal .

dec:respondTo a ns1:ObjectProperty ;
    rdfs:domain dec:ContingencyPlans ;
    rdfs:range dec:FutureScenarios ;
    rdfs:subPropertyOf dul:hasFunction .

dec:supports a ns1:ObjectProperty ;
    rdfs:domain dec:ValueAssessment ;
    rdfs:range dec:DecisionCriteria ;
    rdfs:subPropertyOf dul:hasOutput .

dec:targets a ns1:ObjectProperty ;
    rdfs:domain dec:GoalFormulation ;
    rdfs:range dec:GoalStates ;
    rdfs:subPropertyOf dul:hasGoal .

dec:track a ns1:ObjectProperty ;
    rdfs:domain dec:MonitoringMechanisms ;
    rdfs:range dec:DecisionOutcomes ;
    rdfs:subPropertyOf dul:hasParticipant .

dec:uses a ns1:ObjectProperty ;
    rdfs:domain dec:DecisionMaking,
        dec:GoalFormulation ;
    rdfs:range dec:DeliberativeStrategies,
        dec:PrioritizationCriteria ;
    rdfs:subPropertyOf dul:hasParticipant .

eva: ns1:imports dul: .

eva:AestheticEvaluationSituation a dul:Situation ;
    dul:hasParticipant eva:AestheticJudge ;
    dul:hasSetting eva:AestheticEvaluation,
        eva:AestheticQualities,
        eva:SensoryExperience .

eva:ComparativeEvaluationSituation a dul:Situation ;
    dul:hasParticipant eva:ValueComparer ;
    dul:hasSetting eva:ComparativeJudgment,
        eva:DecisionCriteria,
        eva:TradeOffEvaluations .

eva:MoralEvaluationSituation a dul:Situation ;
    dul:hasParticipant eva:MoralEvaluator ;
    dul:hasSetting eva:EthicalPrinciples,
        eva:MoralJudgments,
        eva:MoralReasoning .

eva:PragmaticJudgmentSituation a dul:Situation ;
    dul:hasParticipant eva:PragmaticEvaluator ;
    dul:hasSetting eva:FeasibilityAssessments,
        eva:GoalSatisfaction,
        eva:PracticalJudgments .

eva:QualityAssessmentSituation a dul:Situation ;
    dul:hasParticipant eva:Evaluator ;
    dul:hasSetting eva:EvaluativeThinking,
        eva:QualityAssessment,
        eva:QualityJudgments .

eva:aimFor a ns1:ObjectProperty ;
    rdfs:domain eva:PracticalJudgments ;
    rdfs:range eva:GoalSatisfaction ;
    rdfs:subPropertyOf dul:hasGoal .

eva:applies a ns1:ObjectProperty ;
    rdfs:domain eva:MoralReasoning,
        eva:QualityAssessment ;
    rdfs:range eva:EthicalPrinciples,
        eva:EvaluationCriteria ;
    rdfs:subPropertyOf dul:hasSetting .

eva:appliesTo a ns1:ObjectProperty ;
    rdfs:domain eva:ComparativeJudgment ;
    rdfs:range eva:ValueDimensions ;
    rdfs:subPropertyOf dul:hasSetting .

eva:conducts a ns1:ObjectProperty ;
    rdfs:domain eva:AestheticJudge,
        eva:Evaluator ;
    rdfs:range eva:AestheticEvaluation,
        eva:QualityAssessment ;
    rdfs:subPropertyOf dul:performs .

eva:consider a ns1:ObjectProperty ;
    rdfs:domain eva:PracticalJudgments ;
    rdfs:range eva:ContextualFactors ;
    rdfs:subPropertyOf dul:hasSetting .

eva:determine a ns1:ObjectProperty ;
    rdfs:domain eva:QualityJudgments ;
    rdfs:range eva:ObjectValue ;
    rdfs:subPropertyOf dul:hasQuality .

eva:determineContext a ns1:ObjectProperty ;
    rdfs:domain eva:QualityJudgments ;
    rdfs:range eva:SituationalQuality ;
    rdfs:subPropertyOf dul:hasQuality .

eva:engagesIn a ns1:ObjectProperty ;
    rdfs:domain eva:ComparativeJudgment,
        eva:Evaluator,
        eva:MoralEvaluator ;
    rdfs:range eva:EvaluativeThinking,
        eva:MoralReasoning,
        eva:TradeOffEvaluations ;
    rdfs:subPropertyOf <http://example.org/gemini/cognitive/common#engagesIn>,
        dul:hasPart,
        dul:performs .

eva:guidedBy a ns1:ObjectProperty ;
    rdfs:domain eva:AestheticEvaluation ;
    rdfs:range eva:AestheticStandards ;
    rdfs:subPropertyOf dul:hasSetting .

eva:influencedBy a ns1:ObjectProperty ;
    rdfs:domain eva:AestheticEvaluation ;
    rdfs:range eva:SubjectiveImpressions ;
    rdfs:subPropertyOf dul:hasSetting .

eva:involves a ns1:ObjectProperty ;
    rdfs:domain eva:AestheticEvaluation ;
    rdfs:range eva:SensoryExperience ;
    rdfs:subPropertyOf <http://example.org/gemini/cognitive/common#involves>,
        dul:hasParticipant .

eva:makes a ns1:ObjectProperty ;
    rdfs:domain eva:PragmaticEvaluator ;
    rdfs:range eva:PracticalJudgments ;
    rdfs:subPropertyOf dul:hasParticipant .

eva:performs a ns1:ObjectProperty ;
    rdfs:domain eva:ValueComparer ;
    rdfs:range eva:ComparativeJudgment ;
    rdfs:subPropertyOf dul:performs .

eva:produces a ns1:ObjectProperty ;
    rdfs:domain eva:EvaluativeThinking,
        eva:MoralReasoning ;
    rdfs:range eva:MoralJudgments,
        eva:QualityJudgments ;
    rdfs:subPropertyOf dul:hasOutput .

eva:referTo a ns1:ObjectProperty ;
    rdfs:domain eva:MoralJudgments ;
    rdfs:range eva:NormativeFrameworks ;
    rdfs:subPropertyOf dul:hasReference .

eva:require a ns1:ObjectProperty ;
    rdfs:domain eva:PracticalJudgments ;
    rdfs:range eva:FeasibilityAssessments ;
    rdfs:subPropertyOf dul:hasParticipant .

eva:requireUtility a ns1:ObjectProperty ;
    rdfs:domain eva:PracticalJudgments ;
    rdfs:range eva:UtilityEvaluations ;
    rdfs:subPropertyOf dul:hasParticipant .

eva:respondTo a ns1:ObjectProperty ;
    rdfs:domain eva:MoralJudgments ;
    rdfs:range eva:MoralConflicts ;
    rdfs:subPropertyOf dul:hasCause .

eva:structuredBy a ns1:ObjectProperty ;
    rdfs:domain eva:ComparativeJudgment ;
    rdfs:range eva:PreferenceStructures ;
    rdfs:subPropertyOf dul:hasSetting .

eva:targets a ns1:ObjectProperty ;
    rdfs:domain eva:AestheticEvaluation,
        eva:QualityAssessment ;
    rdfs:range eva:AestheticQualities,
        eva:TargetObjects ;
    rdfs:subPropertyOf dul:hasParticipant,
        dul:hasQuality .

eva:targetsContext a ns1:ObjectProperty ;
    rdfs:domain eva:QualityAssessment ;
    rdfs:range eva:TargetSituations ;
    rdfs:subPropertyOf dul:hasParticipant .

eva:useMethods a ns1:ObjectProperty ;
    rdfs:domain eva:ComparativeEvaluations ;
    rdfs:range eva:EvaluationMethods ;
    rdfs:subPropertyOf dul:hasParticipant .

eva:useStandards a ns1:ObjectProperty ;
    rdfs:domain eva:ComparativeEvaluations ;
    rdfs:range eva:AssessmentStandards ;
    rdfs:subPropertyOf dul:hasSetting .

eva:usesCriteria a ns1:ObjectProperty ;
    rdfs:domain eva:ComparativeJudgment ;
    rdfs:range eva:DecisionCriteria ;
    rdfs:subPropertyOf dul:hasParticipant .

eva:yields a ns1:ObjectProperty ;
    rdfs:domain eva:EvaluativeThinking ;
    rdfs:range eva:ComparativeEvaluations ;
    rdfs:subPropertyOf dul:hasOutcome .

int: ns1:imports dul: .

int:ActionPlanningSituation a dul:Situation ;
    dul:hasParticipant int:ActionPlanner ;
    dul:hasSetting int:ActionPlans,
        int:ExecutionProcesses,
        int:ImplementationIntentions .

int:GoalPersistenceSituation a dul:Situation ;
    dul:hasParticipant int:LongTermPlanner ;
    dul:hasSetting int:IntentionSustainment,
        int:LongTermGoals,
        int:PersistenceStrategies .

int:HabitualActionSituation a dul:Situation ;
    dul:hasParticipant int:HabitualActor ;
    dul:hasSetting int:ContextualTriggers,
        int:HabitualActions,
        int:IntentionalOverride .

int:IntentionFormationSituation a dul:Situation ;
    dul:hasParticipant int:IntentionalAgent ;
    dul:hasSetting int:CommitmentState,
        int:GoalIntention,
        int:IntentionFormation .

int:IntentionReconsiderationSituation a dul:Situation ;
    dul:hasParticipant int:ReconsideringAgent ;
    dul:hasSetting int:ConflictingIntentions,
        int:GoalAdjustment,
        int:ReconsiderationProcesses .

int:compare a ns1:ObjectProperty ;
    rdfs:domain int:ReconsiderationProcesses ;
    rdfs:range int:ConflictingIntentions ;
    rdfs:subPropertyOf dul:hasParticipant .

int:creates a ns1:ObjectProperty ;
    rdfs:domain int:ActionPlanner ;
    rdfs:range int:ActionPlans ;
    rdfs:subPropertyOf dul:designs .

int:engagesIn a ns1:ObjectProperty ;
    rdfs:domain int:ReconsideringAgent ;

ex:ProgressionStages a owl:Class ;
    rdfs:label "ProgressionStages" ;
    rdfs:comment "Distinct phases in developmental or change processes" ;
    rdfs:subClassOf <dul:State> .

ex:SuccessfulTransitions a owl:Class ;
    rdfs:label "SuccessfulTransitions" ;
    rdfs:comment "Effective completion of change processes" ;
    rdfs:subClassOf <dul:State> .

ex:SystemStability a owl:Class ;
    rdfs:label "SystemStability" ;
    rdfs:comment "Maintenance of essential system functions during change" ;
    rdfs:subClassOf <dul:Quality> .

ex:TransformationOutcomes a owl:Class ;
    rdfs:label "TransformationOutcomes" ;
    rdfs:comment "Results produced by transformational events" ;
    rdfs:subClassOf <dul:Situation> .

ex:TransformationSignals a owl:Class ;
    rdfs:label "TransformationSignals" ;
    rdfs:comment "Cues that suggest significant system modifications" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:TransitionCausation a owl:Class ;

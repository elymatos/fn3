ex:EvolvingSystems a owl:Class ;
    rdfs:label "EvolvingSystems" ;
    rdfs:comment "Systems, organisms, or entities undergoing change" ;
    rdfs:subClassOf <dul:PhysicalObject> .

ex:RapidTransformations a owl:Class ;
    rdfs:label "RapidTransformations" ;

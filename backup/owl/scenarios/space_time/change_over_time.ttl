ex:AdaptiveResponses a owl:Class ;
    rdfs:label "AdaptiveResponses" ;
    rdfs:comment "Flexible reactions to detected changes" ;
    rdfs:subClassOf <dul:Process> .

ex:ChangeDetection a owl:Class ;
    rdfs:label "ChangeDetection" ;
    rdfs:comment "Identification of emerging changes and trends" ;
    rdfs:subClassOf <dul:Process> .

ex:ChangePatterns a owl:Class ;
    rdfs:label "ChangePatterns" ;
    rdfs:comment "Recognizable regularities in how change occurs" ;

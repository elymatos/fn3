ex:TransformationPhases a owl:Class ;
    rdfs:label "TransformationPhases" ;
    rdfs:comment "Periods of significant alteration within change processes" ;
    rdfs:subClassOf <dul:State> .

ex:TransitionPlanning a owl:Class ;
    rdfs:label "TransitionPlanning" ;
    rdfs:comment "Preparation for moving through change processes" ;
    rdfs:subClassOf <dul:Process> .

ex:ChangeImplementation a owl:Class ;
    rdfs:label "ChangeImplementation" ;
    rdfs:comment "Execution of planned modifications" ;
    rdfs:subClassOf <dul:Process> .

ex:CyclicalChanges a owl:Class ;
    rdfs:label "CyclicalChanges" ;
    rdfs:comment "Changes that repeat in regular patterns over time" ;
    rdfs:subClassOf <dul:Process> .

ex:TransformationalEvents a owl:Class ;
    rdfs:label "TransformationalEvents" ;
    rdfs:comment "Specific occurrences that trigger major changes" ;
    rdfs:subClassOf <dul:Event> .

ex:DevelopmentalProcesses a owl:Class ;
    rdfs:label "DevelopmentalProcesses" ;
    rdfs:comment "Systematic changes that occur through stages over time" ;

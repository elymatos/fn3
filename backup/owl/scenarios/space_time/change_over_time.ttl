ex:AbruptTransitions a owl:Class ;
    rdfs:label "AbruptTransitions" ;
    rdfs:comment "Quick shifts from one state or condition to another" ;
    rdfs:subClassOf <dul:Process> .

ex:AdaptingSystems a owl:Class ;
    rdfs:label "AdaptingSystems" ;
    rdfs:comment "Systems undergoing intentional modification" ;
    rdfs:subClassOf <dul:PhysicalObject> .

ex:ChangeCorrections a owl:Class ;
    rdfs:label "ChangeCorrections" ;
    rdfs:comment "Interventions to redirect or modify changes" ;
    rdfs:subClassOf <dul:Process> .

ex:ChangeIndicators a owl:Class ;
    rdfs:label "ChangeIndicators" ;
    rdfs:comment "Signs and signals that reveal ongoing changes" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:ChangeManager a owl:Class ;
    rdfs:label "ChangeManager" ;
    rdfs:comment "Person directing and facilitating planned organizational or system changes" ;
    rdfs:subClassOf <dul:Agent> .

ex:ChangeMonitor a owl:Class ;
    rdfs:label "ChangeMonitor" ;
    rdfs:comment "Person observing and responding to system changes" ;
    rdfs:subClassOf <dul:Agent> .

ex:ChangeObserver a owl:Class ;
    rdfs:label "ChangeObserver" ;
    rdfs:comment "Person monitoring and understanding processes of change over time" ;
    rdfs:subClassOf <dul:Agent> .

ex:ChangeOpportunities a owl:Class ;
    rdfs:label "ChangeOpportunities" ;
    rdfs:comment "Beneficial changes that can be encouraged" ;
    rdfs:subClassOf <dul:Event> .

ex:ChangeResistance a owl:Class ;
    rdfs:label "ChangeResistance" ;
    rdfs:comment "Opposition or reluctance to undergo change" ;
    rdfs:subClassOf <dul:Situation> .

ex:ChangeRhythms a owl:Class ;
    rdfs:label "ChangeRhythms" ;
    rdfs:comment "Temporal patterns in the timing of changes" ;
    rdfs:subClassOf <dul:State> .

ex:ChangeStrategies a owl:Class ;
    rdfs:label "ChangeStrategies" ;
    rdfs:comment "Systematic approaches for implementing change" ;
    rdfs:subClassOf <dul:Process> .

ex:ChangeThreats a owl:Class ;
    rdfs:label "ChangeThreats" ;
    rdfs:comment "Harmful changes that need to be addressed" ;
    rdfs:subClassOf <dul:Event> .

ex:ChangeThresholds a owl:Class ;
    rdfs:label "ChangeThresholds" ;
    rdfs:comment "Critical points where sudden changes are triggered" ;
    rdfs:subClassOf <dul:Event> .

ex:ChangingSystems a owl:Class ;
    rdfs:label "ChangingSystems" ;
    rdfs:comment "Systems undergoing sudden or transformational change" ;
    rdfs:subClassOf <dul:PhysicalObject> .

ex:ControlledChange a owl:Class ;
    rdfs:label "ControlledChange" ;
    rdfs:comment "Managed and directed modification processes" ;
    rdfs:subClassOf <dul:Quality> .

ex:CriticalPoints a owl:Class ;
    rdfs:label "CriticalPoints" ;
    rdfs:comment "Specific conditions where transformational events occur" ;
    rdfs:subClassOf <dul:Event> .

ex:CycleTracker a owl:Class ;
    rdfs:label "CycleTracker" ;
    rdfs:comment "Person identifying and monitoring cyclical patterns of change" ;
    rdfs:subClassOf <dul:Agent> .

ex:CyclicalPredictability a owl:Class ;
    rdfs:label "CyclicalPredictability" ;
    rdfs:comment "Ability to anticipate future changes based on cyclical patterns" ;
    rdfs:subClassOf <dul:Quality> .

ex:CyclicalSystems a owl:Class ;
    rdfs:label "CyclicalSystems" ;
    rdfs:comment "Systems that undergo regular, repeating changes" ;
    rdfs:subClassOf <dul:PhysicalObject> .

ex:DevelopmentalTrends a owl:Class ;
    rdfs:label "DevelopmentalTrends" ;
    rdfs:comment "Directional tendencies in ongoing change processes" ;
    rdfs:subClassOf <dul:State> .

ex:DynamicSystems a owl:Class ;
    rdfs:label "DynamicSystems" ;
    rdfs:comment "Systems that naturally undergo continuous change" ;
    rdfs:subClassOf <dul:PhysicalObject> .

ex:EvolutionarySequences a owl:Class ;
    rdfs:label "EvolutionarySequences" ;
    rdfs:comment "Ordered progressions of change over extended time periods" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:GradualChanges a owl:Class ;

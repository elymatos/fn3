@prefix dul: <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#> .
@prefix ex: <http://example.org/space-time/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:AdaptiveResponsesToChangeCorrections a owl:ObjectProperty ;
    rdfs:comment "implement" ;
    rdfs:domain ex:AdaptiveResponses ;
    rdfs:range ex:ChangeCorrections ;
    rdfs:subPropertyOf <dul:implement> .

ex:ChangeDetectionToAdaptiveResponses a owl:ObjectProperty ;
    rdfs:comment "triggers" ;
    rdfs:domain ex:ChangeDetection ;
    rdfs:range ex:AdaptiveResponses ;
    rdfs:subPropertyOf <dul:triggers> .


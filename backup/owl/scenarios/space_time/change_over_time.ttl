    rdfs:comment "Slow, incremental alterations that accumulate over time" ;
    rdfs:subClassOf <dul:Process> .

ex:MonitoringMethods a owl:Class ;
    rdfs:label "MonitoringMethods" ;
    rdfs:comment "Systematic approaches for tracking change" ;
    rdfs:subClassOf <dul:Process> .

ex:PeriodicVariations a owl:Class ;
    rdfs:label "PeriodicVariations" ;
    rdfs:comment "Regular alterations that occur within cycles" ;
    rdfs:subClassOf <dul:Quality> .

ex:PlannedChanges a owl:Class ;
    rdfs:label "PlannedChanges" ;
    rdfs:comment "Intentional modifications designed to improve systems" ;
    rdfs:subClassOf <dul:Event> .

ex:PositiveChange a owl:Class ;
    rdfs:label "PositiveChange" ;
    rdfs:comment "Beneficial modifications that improve system functioning" ;
    rdfs:subClassOf <dul:Quality> .

ex:ProcessContinuity a owl:Class ;
    rdfs:label "ProcessContinuity" ;
    rdfs:comment "Unbroken connection between sequential change stages" ;

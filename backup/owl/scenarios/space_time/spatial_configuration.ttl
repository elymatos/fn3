@prefix dul: <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#> .
@prefix ex: <http://example.org/space-time/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:BoundaryConflictsToTerritorialOrder a owl:ObjectProperty ;
    rdfs:comment "affect" ;
    rdfs:domain ex:BoundaryConflicts ;
    rdfs:range ex:TerritorialOrder ;
    rdfs:subPropertyOf <dul:affect> .


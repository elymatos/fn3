ex:SpatialPatterns a owl:Class ;
    rdfs:label "SpatialPatterns" ;
    rdfs:comment "Recurring arrangements or structures at specific scales" ;
    rdfs:subClassOf <dul:Description> .

ex:SpatialReasoning a owl:Class ;
    rdfs:label "SpatialReasoning" ;
    rdfs:comment "Cognitive processing of spatial information" ;
    rdfs:subClassOf <dul:Process> .

ex:SpatialThinker a owl:Class ;
    rdfs:label "SpatialThinker" ;
    rdfs:comment "Person reasoning about multi-scale spatial phenomena" ;
    rdfs:subClassOf <dul:Agent> .

ex:TerritorialIndicators a owl:Class ;

ex:BoundaryConflicts a owl:Class ;
    rdfs:label "BoundaryConflicts" ;
    rdfs:comment "Disputes or tensions over spatial limits" ;
    rdfs:subClassOf <dul:Situation> .

ex:BoundaryDefinition a owl:Class ;
    rdfs:label "BoundaryDefinition" ;
    rdfs:comment "Establishing clear spatial limits and divisions" ;
    rdfs:subClassOf <dul:Process> .

ex:BoundaryMarkers a owl:Class ;
    rdfs:label "BoundaryMarkers" ;
    rdfs:comment "Physical or conceptual indicators of spatial limits" ;
    rdfs:subClassOf <dul:PhysicalObject> .

ex:ContainmentRelations a owl:Class ;
    rdfs:label "ContainmentRelations" ;
    rdfs:comment "Inside/outside, enclosure relationships" ;
    rdfs:subClassOf <dul:Relation> .

ex:DesignPrinciples a owl:Class ;
    rdfs:label "DesignPrinciples" ;
    rdfs:comment "Guidelines for creating effective spatial arrangements" ;
    rdfs:subClassOf <dul:Description> .

ex:DirectionalOrientations a owl:Class ;
    rdfs:label "DirectionalOrientations" ;
    rdfs:comment "Angular or compass-based positioning" ;
    rdfs:subClassOf <dul:Relation> .

ex:DistanceRelations a owl:Class ;
    rdfs:label "DistanceRelations" ;
    rdfs:comment "Near/far relationships between objects" ;
    rdfs:subClassOf <dul:Relation> .

ex:EfficiencyFactors a owl:Class ;
    rdfs:label "EfficiencyFactors" ;
    rdfs:comment "Elements that contribute to effective space utilization" ;
    rdfs:subClassOf <dul:Quality> .

ex:FunctionalLayouts a owl:Class ;
    rdfs:label "FunctionalLayouts" ;
    rdfs:comment "Spatial arrangements that effectively support intended activities" ;
    rdfs:subClassOf <dul:Region> .

ex:FunctionalZones a owl:Class ;
    rdfs:label "FunctionalZones" ;
    rdfs:comment "Areas designated for particular activities or purposes" ;
    rdfs:subClassOf <dul:Region> .

ex:GeographicEnvironments a owl:Class ;
    rdfs:label "GeographicEnvironments" ;
    rdfs:comment "Physical spaces with navigable features" ;
    rdfs:subClassOf <dul:PhysicalObject> .

ex:HarmoniousArrangements a owl:Class ;
    rdfs:label "HarmoniousArrangements" ;
    rdfs:comment "Spatial configurations that create aesthetic and functional balance" ;
    rdfs:subClassOf <dul:State> .

ex:HierarchicalOrganization a owl:Class ;
    rdfs:label "HierarchicalOrganization" ;
    rdfs:comment "Nested structure of spatial scales" ;
    rdfs:subClassOf <dul:State> .

ex:LandmarkIdentification a owl:Class ;
    rdfs:label "LandmarkIdentification" ;
    rdfs:comment "Recognition of distinctive spatial features" ;
    rdfs:subClassOf <dul:Process> .

ex:LayoutDesigner a owl:Class ;
    rdfs:label "LayoutDesigner" ;
    rdfs:comment "Person creating optimized spatial arrangements and designs" ;
    rdfs:subClassOf <dul:Agent> .

ex:MacroscaleStructures a owl:Class ;
    rdfs:label "MacroscaleStructures" ;
    rdfs:comment "Large-scale spatial organizations" ;
    rdfs:subClassOf <dul:PhysicalObject> .

ex:MicroscaleFeatures a owl:Class ;
    rdfs:label "MicroscaleFeatures" ;
    rdfs:comment "Small-scale spatial patterns and structures" ;
    rdfs:subClassOf <dul:PhysicalObject> .

ex:Navigator a owl:Class ;
    rdfs:label "Navigator" ;
    rdfs:comment "Person exploring and mapping spatial environments" ;
    rdfs:subClassOf <dul:Agent> .

ex:Observer a owl:Class ;
    rdfs:label "Observer" ;
    rdfs:comment "Person perceiving and reasoning about spatial arrangements" ;
    rdfs:subClassOf <dul:Agent> .

ex:ScaleRelationships a owl:Class ;
    rdfs:label "ScaleRelationships" ;
    rdfs:comment "Connections between phenomena at different scales" ;
    rdfs:subClassOf <dul:Relation> .

ex:ScaleTransition a owl:Class ;
    rdfs:label "ScaleTransition" ;
    rdfs:comment "Moving between different levels of spatial analysis" ;
    rdfs:subClassOf <dul:Process> .

ex:SpaceAllocation a owl:Class ;
    rdfs:label "SpaceAllocation" ;
    rdfs:comment "Assigning spatial areas for specific purposes" ;
    rdfs:subClassOf <dul:Process> .

ex:SpatialAccess a owl:Class ;
    rdfs:label "SpatialAccess" ;
    rdfs:comment "Control and regulation of movement through territories" ;
    rdfs:subClassOf <dul:Process> .

ex:SpatialAnalysis a owl:Class ;
    rdfs:label "SpatialAnalysis" ;
    rdfs:comment "Systematic examination of spatial relationships and flows" ;
    rdfs:subClassOf <dul:Process> .

ex:SpatialConstraints a owl:Class ;
    rdfs:label "SpatialConstraints" ;
    rdfs:comment "Limitations and restrictions affecting layout design" ;
    rdfs:subClassOf <dul:Situation> .

ex:SpatialEfficiency a owl:Class ;
    rdfs:label "SpatialEfficiency" ;

@prefix dul: <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#> .
@prefix ex: <http://example.org/space-time/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:ActivityEngagementToTemporalPerception a owl:ObjectProperty ;
    rdfs:comment "modulates" ;
    rdfs:domain ex:ActivityEngagement ;
    rdfs:range ex:TemporalPerception ;
    rdfs:subPropertyOf <dul:modulates> .


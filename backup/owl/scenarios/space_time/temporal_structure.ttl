ex:ActivityEngagement a owl:Class ;
    rdfs:label "ActivityEngagement" ;
    rdfs:comment "Level of involvement and attention devoted to current activities" ;
    rdfs:subClassOf <dul:State> .

ex:ChangingCircumstances a owl:Class ;
    rdfs:label "ChangingCircumstances" ;
    rdfs:comment "Evolving conditions that affect temporal planning" ;
    rdfs:subClassOf <dul:Situation> .

ex:ChronologicalSystems a owl:Class ;
    rdfs:label "ChronologicalSystems" ;
    rdfs:comment "Ordered arrangements for measuring and tracking time" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:ConcurrentActivities a owl:Class ;
    rdfs:label "ConcurrentActivities" ;
    rdfs:comment "Activities happening simultaneously that need coordination" ;
    rdfs:subClassOf <dul:Process> .

ex:CoordinatedTiming a owl:Class ;
    rdfs:label "CoordinatedTiming" ;
    rdfs:comment "Successfully synchronized temporal relationships" ;
    rdfs:subClassOf <dul:Quality> .

ex:CyclicalOccurrences a owl:Class ;
    rdfs:label "CyclicalOccurrences" ;
    rdfs:comment "Events that happen as part of recurring temporal cycles" ;
    rdfs:subClassOf <dul:Event> .

ex:DurationVariations a owl:Class ;
    rdfs:label "DurationVariations" ;
    rdfs:comment "Differences in perceived length of similar objective time periods" ;
    rdfs:subClassOf <dul:Quality> .

ex:FlexibilityStrategies a owl:Class ;
    rdfs:label "FlexibilityStrategies" ;
    rdfs:comment "Approaches for maintaining temporal adaptability" ;

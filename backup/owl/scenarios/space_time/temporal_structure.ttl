    rdfs:comment "Ordered patterns of temporal intervals" ;
    rdfs:subClassOf <dul:InformationObject> .

ex:ScheduleStability a owl:Class ;
    rdfs:label "ScheduleStability" ;
    rdfs:comment "Maintenance of reliable temporal structure" ;
    rdfs:subClassOf <dul:Quality> .

ex:SeasonalPatterns a owl:Class ;
    rdfs:label "SeasonalPatterns" ;
    rdfs:comment "Cyclical changes associated with annual environmental cycles" ;
    rdfs:subClassOf <dul:State> .

ex:SubjectiveTime a owl:Class ;

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DUL Ontology - Enhanced Interactive Graph</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/d3/7.8.5/d3.min.js"></script>
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f5f7fa;
            overflow: hidden;
        }

        .container {
            position: relative;
            width: 100vw;
            height: 100vh;
        }

        .header {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            background: rgba(52, 73, 94, 0.95);
            color: white;
            padding: 15px 20px;
            z-index: 1000;
            backdrop-filter: blur(10px);
            border-bottom: 2px solid #34495e;
        }

        .header h1 {
            margin: 0;
            font-size: 1.8em;
            font-weight: 300;
        }

        .header p {
            margin: 5px 0 0 0;
            font-size: 0.9em;
            opacity: 0.8;
        }

        .controls {
            position: absolute;
            top: 90px;
            right: 20px;
            background: rgba(255, 255, 255, 0.95);
            padding: 15px;
            border-radius: 10px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
            z-index: 1000;
            min-width: 250px;
            max-height: calc(100vh - 120px);
            overflow-y: auto;
        }

        .control-group {
            margin-bottom: 15px;
        }

        .control-group:last-child {
            margin-bottom: 0;
        }

        .control-group label {
            display: block;
            font-weight: 600;
            margin-bottom: 5px;
            color: #2c3e50;
            font-size: 0.9em;
        }

        .control-group input, .control-group select {
            width: 100%;
            padding: 8px;
            border: 2px solid #e9ecef;
            border-radius: 5px;
            font-size: 0.85em;
        }

        .control-group input:focus, .control-group select:focus {
            outline: none;
            border-color: #007bff;
        }

        .legend {
            position: absolute;
            bottom: 20px;
            left: 20px;
            background: rgba(255, 255, 255, 0.95);
            padding: 15px;
            border-radius: 10px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
            z-index: 1000;
            max-width: 300px;
        }

        .legend h3 {
            margin: 0 0 10px 0;
            font-size: 1.1em;
            color: #2c3e50;
        }

        .legend-item {
            display: flex;
            align-items: center;
            margin: 5px 0;
            font-size: 0.85em;
        }

        .legend-line {
            width: 30px;
            height: 2px;
            margin-right: 8px;
        }

        .graph-container {
            width: 100%;
            height: 100%;
        }

        .node {
            cursor: pointer;
            stroke: #fff;
            stroke-width: 2px;
            transition: all 0.3s ease;
        }

        .node.dragging {
            transition: none;
        }

        .node:hover {
            stroke-width: 4px;
            filter: drop-shadow(0 0 8px rgba(255,255,255,0.8));
        }

        .node-duplicate {
            stroke-dasharray: 5, 5;
            opacity: 0.7;
        }

        .node-expanded {
            stroke-width: 3px;
            stroke: #ffd700;
        }

        .node-collapsed {
            opacity: 0.6;
        }

        .link {
            fill: none;
            stroke-opacity: 0.6;
            stroke-width: 2px;
            marker-end: url(#arrowhead);
        }

        .link-subclass {
            stroke: #555;
            stroke-width: 2.5px;
        }

        .link-property {
            stroke: #3498db;
            stroke-dasharray: 5, 3;
        }

        .link:hover {
            stroke-opacity: 1;
            stroke-width: 4px;
        }

        .node-label {
            font-size: 10px;
            font-weight: 600;
            text-anchor: middle;
            pointer-events: none;
            fill: #2c3e50;
            text-shadow: 1px 1px 2px rgba(255,255,255,0.9);
        }

        .link-label {
            font-size: 7px;
            text-anchor: middle;
            pointer-events: none;
            fill: #2c3e50;
            font-weight: 500;
            opacity: 0.8;
        }

        .link-label-bg {
            fill: rgba(255, 255, 255, 0.85);
            stroke: #ddd;
            stroke-width: 0.5px;
            rx: 2px;
            ry: 2px;
            opacity: 0.8;
        }

        .tooltip {
            position: absolute;
            background: rgba(0, 0, 0, 0.9);
            color: white;
            padding: 10px 15px;
            border-radius: 8px;
            font-size: 0.85em;
            pointer-events: none;
            z-index: 2000;
            max-width: 350px;
            line-height: 1.4;
            display: none;
        }

        .tooltip h4 {
            margin: 0 0 5px 0;
            color: #ffd700;
        }

        .definition-sidebar {
            position: absolute;
            left: 0;
            top: 90px;
            bottom: 0;
            width: 400px;
            background: white;
            border-right: 2px solid #3498db;
            box-shadow: 2px 0 10px rgba(0,0,0,0.1);
            z-index: 999;
            padding: 20px;
            overflow-y: auto;
            transform: translateX(-100%);
            transition: transform 0.3s ease;
        }

        .definition-sidebar.visible {
            transform: translateX(0);
        }

        .definition-sidebar h3 {
            margin: 0 0 15px 0;
            color: #2c3e50;
            border-bottom: 2px solid #3498db;
            padding-bottom: 10px;
            font-size: 1.4em;
        }

        .definition-sidebar .class-uri {
            font-size: 0.8em;
            color: #7f8c8d;
            margin-bottom: 15px;
            word-break: break-all;
        }

        .definition-sidebar .definition-content {
            margin: 15px 0;
            color: #555;
            line-height: 1.6;
            font-size: 0.95em;
        }

        .definition-sidebar .close-btn {
            position: absolute;
            top: 15px;
            right: 15px;
            background: #e74c3c;
            color: white;
            border: none;
            border-radius: 50%;
            width: 30px;
            height: 30px;
            cursor: pointer;
            font-size: 18px;
            line-height: 1;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .definition-sidebar .close-btn:hover {
            background: #c0392b;
        }

        .definition-sidebar .metadata {
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid #e0e0e0;
        }

        .definition-sidebar .metadata-item {
            margin: 10px 0;
            font-size: 0.9em;
        }

        .definition-sidebar .metadata-label {
            font-weight: 600;
            color: #2c3e50;
        }

        .definition-sidebar .metadata-value {
            color: #7f8c8d;
        }

        .reset-button {
            background: #007bff;
            color: white;
            border: none;
            padding: 8px 12px;
            border-radius: 5px;
            cursor: pointer;
            font-size: 0.85em;
            width: 100%;
        }

        .reset-button:hover {
            background: #0056b3;
        }

        .loading {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: white;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
            z-index: 3000;
        }

        .spinner {
            border: 4px solid #f3f3f3;
            border-top: 4px solid #3498db;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
            margin: 0 auto 15px;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        #arrowhead {
            fill: #666;
        }

        .stats {
            background: rgba(255, 255, 255, 0.95);
            padding: 10px;
            border-radius: 5px;
            margin-bottom: 10px;
            font-size: 0.85em;
        }

        .stats-item {
            display: flex;
            justify-content: space-between;
            margin: 3px 0;
        }

        .stats-label {
            font-weight: 600;
            color: #555;
        }

        .stats-value {
            color: #007bff;
            font-weight: 600;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>DUL Ontology - Enhanced Interactive Graph</h1>
            <p>Click to see definition • Double-click to focus on node • Hover links for property names</p>
        </div>

        <div class="controls">
            <div class="stats">
                <div class="stats-item">
                    <span class="stats-label">Visible:</span>
                    <span class="stats-value" id="stat-visible">0</span>
                </div>
                <div class="stats-item">
                    <span class="stats-label">Total Classes:</span>
                    <span class="stats-value" id="stat-classes">0</span>
                </div>
                <div class="stats-item">
                    <span class="stats-label">Properties:</span>
                    <span class="stats-value" id="stat-properties">0</span>
                </div>
            </div>

            <div class="control-group">
                <label>Search Nodes:</label>
                <input type="text" id="searchInput" placeholder="Type class name...">
            </div>

            <div class="control-group">
                <label>Show Links:</label>
                <select id="linkTypeFilter">
                    <option value="all">All Links</option>
                    <option value="subclass">Subclass Only</option>
                    <option value="property">Properties Only</option>
                </select>
            </div>

            <div class="control-group">
                <button class="reset-button" onclick="resetGraph()">Reset to Entity</button>
            </div>
        </div>


        <div class="graph-container">
            <svg id="graph"></svg>
        </div>

        <div class="loading" id="loading">
            <div class="spinner"></div>
            <p>Loading DUL Ontology...</p>
        </div>

        <div class="tooltip" id="tooltip"></div>

        <div class="definition-sidebar" id="definition-sidebar">
            <button class="close-btn" onclick="hideDefinition()">×</button>
            <h3 id="def-title"></h3>
            <div class="class-uri" id="def-uri"></div>
            <div class="definition-content" id="def-content"></div>
            <div class="metadata" id="def-metadata"></div>
        </div>
    </div>

    <script>
        // Global variables
        let allNodes = [];
        let allLinks = [];
        let visibleNodeIds = new Set();
        let expandedNodeIds = new Set();
        let nodeElements, linkElements, labelElements, linkLabelGroups;
        let rawOntologyData = null;
        const width = window.innerWidth;
        const height = window.innerHeight;

        // Set up SVG
        const svg = d3.select("#graph")
            .attr("width", width)
            .attr("height", height);

        const g = svg.append("g");

        // Define arrow marker (smaller)
        svg.append("defs").append("marker")
            .attr("id", "arrowhead")
            .attr("viewBox", "0 -5 10 10")
            .attr("refX", 18)
            .attr("refY", 0)
            .attr("markerWidth", 4)
            .attr("markerHeight", 4)
            .attr("orient", "auto")
            .append("path")
            .attr("d", "M0,-5L10,0L0,5")
            .attr("fill", "#666");

        // Tooltip
        const tooltip = d3.select("#tooltip");

        // Color scheme for node types
        const colorScheme = {
            'Entity': '#3498db',
            'Object': '#e74c3c',
            'Event': '#f39c12',
            'SocialObject': '#9b59b6',
            'Abstract': '#1abc9c',
            'Quality': '#e67e22',
            'default': '#95a5a6'
        };

        // Load and parse ontology
        async function loadOntology() {
            try {
                const response = await fetch('DUL.jsonld');
                const data = await response.json();
                rawOntologyData = data;

                parseOntology(data);

                // Start with Entity only
                const entityUri = 'http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity';
                visibleNodeIds.add(entityUri);
                expandNode(entityUri);

                createVisualization();
                updateStats();

                document.getElementById('loading').style.display = 'none';
            } catch (error) {
                console.error('Error loading ontology:', error);
                document.getElementById('loading').innerHTML =
                    '<p style="color: red;">Error loading ontology. Please check the console.</p>';
            }
        }

        function extractName(uri) {
            if (uri.includes('#')) {
                return uri.split('#').pop();
            }
            return uri.split('/').pop();
        }

        function extractLabel(item) {
            const labelField = item['http://www.w3.org/2000/01/rdf-schema#label'] ||
                             item['rdfs:label'];
            if (!labelField) return null;

            const labels = Array.isArray(labelField) ? labelField : [labelField];

            // Prefer English labels
            const englishLabel = labels.find(l =>
                typeof l === 'object' && l['@language'] === 'en' && l['@value']
            );
            if (englishLabel) return englishLabel['@value'];

            // Fall back to first available label
            const firstLabel = labels[0];
            if (typeof firstLabel === 'object' && firstLabel['@value']) {
                return firstLabel['@value'];
            } else if (typeof firstLabel === 'string') {
                return firstLabel;
            }
            return null;
        }

        function extractDefinition(item) {
            const commentField = item['http://www.w3.org/2000/01/rdf-schema#comment'] ||
                               item['rdfs:comment'];
            if (!commentField) return '';

            const comments = Array.isArray(commentField) ? commentField : [commentField];
            const comment = comments[0];

            if (typeof comment === 'object' && comment['@value']) {
                return comment['@value'];
            } else if (typeof comment === 'string') {
                return comment;
            }
            return '';
        }

        function parseOntology(data) {
            const items = Array.isArray(data) ? data : (data['@graph'] || [data]);

            const classes = new Map();
            const properties = new Map();
            const processedLinks = new Set();
            const selfPropertyCounter = new Map();

            // First pass: Extract classes and properties with definitions
            items.forEach(item => {
                if (!item['@id'] || item['@id'].startsWith('_:') ||
                    !item['@id'].includes('ont/dul/DUL.owl#')) {
                    return;
                }

                const uri = item['@id'];
                const types = Array.isArray(item['@type']) ? item['@type'] : [item['@type']];

                // Process classes
                if (types.some(t => t.includes('Class'))) {
                    const name = extractName(uri);
                    if (!classes.has(uri)) {
                        classes.set(uri, {
                            id: uri,
                            name: name,
                            label: name,
                            type: 'class',
                            superClasses: [],
                            subClasses: [],
                            definition: extractDefinition(item)
                        });
                    }
                }

                // Process object properties
                if (types.some(t => t.includes('ObjectProperty'))) {
                    const name = extractName(uri);
                    const label = extractLabel(item);
                    const displayName = label || name;

                    const domainData = item['http://www.w3.org/2000/01/rdf-schema#domain'] ||
                                      item['rdfs:domain'];
                    const domains = domainData ? (Array.isArray(domainData) ? domainData : [domainData]) : [];

                    const rangeData = item['http://www.w3.org/2000/01/rdf-schema#range'] ||
                                     item['rdfs:range'];
                    const ranges = rangeData ? (Array.isArray(rangeData) ? rangeData : [rangeData]) : [];

                    const inverseData = item['http://www.w3.org/2002/07/owl#inverseOf'] ||
                                       item['owl:inverseOf'];
                    const inverse = inverseData ? (Array.isArray(inverseData) ? inverseData[0] : inverseData) : null;

                    properties.set(uri, {
                        id: uri,
                        name: name,
                        displayName: displayName,
                        domains: domains.map(d => typeof d === 'object' ? d['@id'] : d).filter(Boolean),
                        ranges: ranges.map(r => typeof r === 'object' ? r['@id'] : r).filter(Boolean),
                        inverse: inverse ? (typeof inverse === 'object' ? inverse['@id'] : inverse) : null
                    });
                }
            });

            // Second pass: Build subclass relationships
            items.forEach(item => {
                if (!item['@id'] || !classes.has(item['@id'])) return;

                const uri = item['@id'];
                const classData = classes.get(uri);

                const subClassData = item['http://www.w3.org/2000/01/rdf-schema#subClassOf'] ||
                                    item['rdfs:subClassOf'];
                if (subClassData) {
                    const superClasses = Array.isArray(subClassData) ? subClassData : [subClassData];
                    superClasses.forEach(sc => {
                        const superUri = typeof sc === 'object' ? sc['@id'] : sc;
                        if (superUri && classes.has(superUri) && !superUri.startsWith('_:')) {
                            classData.superClasses.push(superUri);
                            classes.get(superUri).subClasses.push(uri);

                            const linkKey = `${superUri}->${uri}-subClassOf`;
                            if (!processedLinks.has(linkKey)) {
                                allLinks.push({
                                    source: superUri,
                                    target: uri,
                                    type: 'subclass',
                                    property: 'subClassOf'
                                });
                                processedLinks.add(linkKey);
                            }
                        }
                    });
                }
            });

            // Third pass: Build property links
            const processedInverses = new Set();

            properties.forEach((prop, propUri) => {
                if (processedInverses.has(propUri)) return;

                prop.domains.forEach(domain => {
                    if (!classes.has(domain)) return;

                    prop.ranges.forEach(range => {
                        if (!classes.has(range)) return;

                        let displayLabel = prop.displayName;
                        let inverseProperty = null;

                        if (prop.inverse && properties.has(prop.inverse)) {
                            const invProp = properties.get(prop.inverse);
                            if (invProp.domains.includes(range) && invProp.ranges.includes(domain)) {
                                inverseProperty = invProp;
                                // Only combine if the labels are different
                                if (prop.displayName !== invProp.displayName) {
                                    displayLabel = `${prop.displayName} | ${invProp.displayName}`;
                                }
                                processedInverses.add(prop.inverse);
                            }
                        }

                        // Handle self-referencing properties
                        if (domain === range) {
                            const selfKey = `${domain}-${propUri}`;
                            if (!selfPropertyCounter.has(domain)) {
                                selfPropertyCounter.set(domain, 0);
                            }
                            const count = selfPropertyCounter.get(domain);
                            selfPropertyCounter.set(domain, count + 1);

                            const duplicateId = `${domain}_dup${count}`;
                            const originalClass = classes.get(domain);
                            classes.set(duplicateId, {
                                id: duplicateId,
                                name: `${originalClass.name}'`,
                                label: originalClass.label,
                                type: 'class-duplicate',
                                originalId: domain,
                                superClasses: [],
                                subClasses: [],
                                definition: originalClass.definition
                            });

                            const linkKey = `${domain}->${duplicateId}-${propUri}`;
                            if (!processedLinks.has(linkKey)) {
                                allLinks.push({
                                    source: domain,
                                    target: duplicateId,
                                    type: 'property',
                                    property: displayLabel,
                                    propertyUri: propUri,
                                    isSelfProperty: true
                                });
                                processedLinks.add(linkKey);
                            }
                        } else {
                            const linkKey = `${domain}->${range}-${propUri}`;
                            if (!processedLinks.has(linkKey)) {
                                allLinks.push({
                                    source: domain,
                                    target: range,
                                    type: 'property',
                                    property: displayLabel,
                                    propertyUri: propUri,
                                    hasInverse: inverseProperty !== null
                                });
                                processedLinks.add(linkKey);
                            }
                        }
                    });
                });
            });

            // Convert classes to nodes array
            allNodes = Array.from(classes.values()).map(c => ({
                ...c,
                color: null,
                visible: false
            }));

            // Assign colors
            allNodes.forEach(node => {
                node.color = getNodeColor(node, classes);
            });

            document.getElementById('stat-classes').textContent =
                allNodes.filter(n => n.type === 'class').length;
            document.getElementById('stat-properties').textContent = properties.size;

            console.log(`Parsed ${allNodes.length} nodes and ${allLinks.length} links`);
        }

        function expandNode(nodeId) {
            const node = allNodes.find(n => n.id === nodeId);
            if (!node) return;

            // Clear all previous visible nodes and expanded nodes
            visibleNodeIds.clear();
            expandedNodeIds.clear();

            // Mark this node as expanded and visible
            expandedNodeIds.add(nodeId);
            visibleNodeIds.add(nodeId);

            // Add only directly related nodes to this node
            allLinks.forEach(link => {
                if (link.source === nodeId || (typeof link.source === 'object' && link.source.id === nodeId)) {
                    const targetId = typeof link.target === 'object' ? link.target.id : link.target;
                    visibleNodeIds.add(targetId);
                }
                if (link.target === nodeId || (typeof link.target === 'object' && link.target.id === nodeId)) {
                    const sourceId = typeof link.source === 'object' ? link.source.id : link.source;
                    visibleNodeIds.add(sourceId);
                }
            });
        }

        function collapseNode(nodeId) {
            expandedNodeIds.delete(nodeId);

            // Remove nodes that are only connected through this node
            const nodesToCheck = new Set();
            allLinks.forEach(link => {
                const sourceId = typeof link.source === 'object' ? link.source.id : link.source;
                const targetId = typeof link.target === 'object' ? link.target.id : link.target;

                if (sourceId === nodeId) nodesToCheck.add(targetId);
                if (targetId === nodeId) nodesToCheck.add(sourceId);
            });

            nodesToCheck.forEach(id => {
                if (id === nodeId) return;

                // Check if this node has other visible connections
                let hasOtherConnections = false;
                allLinks.forEach(link => {
                    const sourceId = typeof link.source === 'object' ? link.source.id : link.source;
                    const targetId = typeof link.target === 'object' ? link.target.id : link.target;

                    if ((sourceId === id && visibleNodeIds.has(targetId) && targetId !== nodeId) ||
                        (targetId === id && visibleNodeIds.has(sourceId) && sourceId !== nodeId)) {
                        hasOtherConnections = true;
                    }
                });

                if (!hasOtherConnections && !expandedNodeIds.has(id)) {
                    visibleNodeIds.delete(id);
                }
            });
        }

        function getNodeColor(node, classes) {
            if (node.type === 'class-duplicate') {
                const originalNode = allNodes.find(n => n.id === node.originalId);
                if (originalNode && originalNode.color) {
                    return originalNode.color;
                }
                if (classes && classes.has(node.originalId)) {
                    return getNodeColor(classes.get(node.originalId), classes);
                }
                return colorScheme.default;
            }

            const name = node.name;
            if (name === 'Entity') return colorScheme.Entity;

            const ancestors = getAllAncestors(node);
            if (ancestors.includes('http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Object'))
                return colorScheme.Object;
            if (ancestors.includes('http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Event'))
                return colorScheme.Event;
            if (ancestors.includes('http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#SocialObject'))
                return colorScheme.SocialObject;
            if (ancestors.includes('http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Abstract'))
                return colorScheme.Abstract;
            if (ancestors.includes('http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Quality'))
                return colorScheme.Quality;

            return colorScheme.default;
        }

        function getAllAncestors(node, visited = new Set()) {
            if (visited.has(node.id)) return [];
            visited.add(node.id);

            let ancestors = [...node.superClasses];
            node.superClasses.forEach(superId => {
                const superNode = allNodes.find(n => n.id === superId);
                if (superNode) {
                    ancestors = ancestors.concat(getAllAncestors(superNode, visited));
                }
            });
            return ancestors;
        }

        function updateStats() {
            document.getElementById('stat-visible').textContent = visibleNodeIds.size;
        }

        function calculateStaticLayout(nodes, links) {
            const centerX = width / 2;
            const centerY = height / 2;

            // If only one node, place it in center
            if (nodes.length === 1) {
                nodes[0].x = centerX;
                nodes[0].y = centerY;
                return;
            }

            // Use circular layout for multiple nodes
            const radius = Math.min(width, height) * 0.3;
            const angleStep = (2 * Math.PI) / nodes.length;

            nodes.forEach((node, i) => {
                const angle = i * angleStep;
                node.x = centerX + radius * Math.cos(angle);
                node.y = centerY + radius * Math.sin(angle);
            });
        }

        function updatePositions() {
            // Update link positions
            linkElements
                .attr("x1", d => {
                    const source = typeof d.source === 'object' ? d.source : allNodes.find(n => n.id === d.source);
                    return source ? source.x : 0;
                })
                .attr("y1", d => {
                    const source = typeof d.source === 'object' ? d.source : allNodes.find(n => n.id === d.source);
                    return source ? source.y : 0;
                })
                .attr("x2", d => {
                    const target = typeof d.target === 'object' ? d.target : allNodes.find(n => n.id === d.target);
                    return target ? target.x : 0;
                })
                .attr("y2", d => {
                    const target = typeof d.target === 'object' ? d.target : allNodes.find(n => n.id === d.target);
                    return target ? target.y : 0;
                });

            // Update node positions
            nodeElements
                .attr("cx", d => d.x)
                .attr("cy", d => d.y);

            // Update label positions
            labelElements
                .attr("x", d => d.x)
                .attr("y", d => d.y + 4);

            // Update link label positions
            linkLabelGroups.each(function(d) {
                const source = typeof d.source === 'object' ? d.source : allNodes.find(n => n.id === d.source);
                const target = typeof d.target === 'object' ? d.target : allNodes.find(n => n.id === d.target);

                if (!source || !target) return;

                const x = (source.x + target.x) / 2;
                const y = (source.y + target.y) / 2;

                const text = d3.select(this).select("text");
                text.attr("x", x).attr("y", y);

                const bbox = text.node().getBBox();
                d3.select(this).select("rect")
                    .attr("x", bbox.x - 2)
                    .attr("y", bbox.y - 1)
                    .attr("width", bbox.width + 4)
                    .attr("height", bbox.height + 2);
            });
        }

        function createVisualization() {
            // Filter visible nodes and links
            const nodes = allNodes.filter(n => visibleNodeIds.has(n.id));
            const links = allLinks.filter(l => {
                const sourceId = typeof l.source === 'object' ? l.source.id : l.source;
                const targetId = typeof l.target === 'object' ? l.target.id : l.target;
                return visibleNodeIds.has(sourceId) && visibleNodeIds.has(targetId);
            });

            // Clear existing elements
            g.selectAll("*").remove();

            // Calculate static positions
            calculateStaticLayout(nodes, links);

            // Create links
            const linkGroup = g.append("g").attr("class", "links");
            linkElements = linkGroup.selectAll("line")
                .data(links)
                .enter().append("line")
                .attr("class", d => `link link-${d.type}`)
                .on("mouseover", showLinkTooltip)
                .on("mouseout", hideTooltip);

            // Create link labels
            linkLabelGroups = g.append("g").attr("class", "link-labels")
                .selectAll("g")
                .data(links)
                .enter().append("g");

            linkLabelGroups.append("rect")
                .attr("class", "link-label-bg");

            linkLabelGroups.append("text")
                .attr("class", "link-label")
                .text(d => d.property || d.type);

            // Create nodes
            const nodeGroup = g.append("g").attr("class", "nodes");
            nodeElements = nodeGroup.selectAll("circle")
                .data(nodes)
                .enter().append("circle")
                .attr("class", d => {
                    let classes = 'node';
                    if (d.type === 'class-duplicate') classes += ' node-duplicate';
                    if (expandedNodeIds.has(d.id)) classes += ' node-expanded';
                    return classes;
                })
                .attr("r", d => d.type === 'class-duplicate' ? 8 : 10)
                .style("fill", d => d.color)
                .call(d3.drag()
                    .on("start", dragstarted)
                    .on("drag", dragged)
                    .on("end", dragended))
                .on("click", function(event, d) {
                    event.stopPropagation();
                    showDefinition(d);
                })
                .on("dblclick", function(event, d) {
                    event.stopPropagation();
                    if (expandedNodeIds.has(d.id)) {
                        collapseNode(d.id);
                    } else {
                        expandNode(d.id);
                    }
                    updateVisualization();
                });

            // Create labels
            const labelGroup = g.append("g").attr("class", "labels");
            labelElements = labelGroup.selectAll("text")
                .data(nodes)
                .enter().append("text")
                .attr("class", "node-label")
                .text(d => d.name)
                .style("font-size", d => d.type === 'class-duplicate' ? '8px' : '10px');

            // Set initial positions immediately (no animation)
            updatePositions();

            // Zoom behavior
            const zoom = d3.zoom()
                .scaleExtent([0.1, 4])
                .on("zoom", (event) => {
                    g.attr("transform", event.transform);
                });

            svg.call(zoom);

            setupControls();
        }

        function updateVisualization() {
            createVisualization();
            updateStats();
        }

        function showDefinition(node) {
            const sidebar = document.getElementById('definition-sidebar');
            const title = document.getElementById('def-title');
            const uri = document.getElementById('def-uri');
            const content = document.getElementById('def-content');
            const metadata = document.getElementById('def-metadata');

            title.textContent = node.name;
            uri.textContent = node.id;
            content.textContent = node.definition || 'No definition available.';

            // Build metadata
            let metadataHtml = '';
            if (node.type === 'class-duplicate') {
                metadataHtml += '<div class="metadata-item">';
                metadataHtml += '<span class="metadata-label">Type:</span> ';
                metadataHtml += '<span class="metadata-value">Duplicate node for self-referencing property</span>';
                metadataHtml += '</div>';
                metadataHtml += '<div class="metadata-item">';
                metadataHtml += '<span class="metadata-label">Original:</span> ';
                metadataHtml += '<span class="metadata-value">' + extractName(node.originalId) + '</span>';
                metadataHtml += '</div>';
            } else {
                if (node.superClasses && node.superClasses.length > 0) {
                    metadataHtml += '<div class="metadata-item">';
                    metadataHtml += '<span class="metadata-label">Superclasses:</span> ';
                    metadataHtml += '<span class="metadata-value">' + node.superClasses.length + '</span>';
                    metadataHtml += '</div>';
                }
                if (node.subClasses && node.subClasses.length > 0) {
                    metadataHtml += '<div class="metadata-item">';
                    metadataHtml += '<span class="metadata-label">Subclasses:</span> ';
                    metadataHtml += '<span class="metadata-value">' + node.subClasses.length + '</span>';
                    metadataHtml += '</div>';
                }
                metadataHtml += '<div class="metadata-item">';
                metadataHtml += '<span class="metadata-label">Status:</span> ';
                metadataHtml += '<span class="metadata-value">' + (expandedNodeIds.has(node.id) ? 'Expanded' : 'Collapsed') + '</span>';
                metadataHtml += '</div>';
            }
            metadata.innerHTML = metadataHtml;

            sidebar.classList.add('visible');
        }

        function hideDefinition() {
            document.getElementById('definition-sidebar').classList.remove('visible');
        }

        function showNodeTooltip(event, d) {
            let html = `<h4>${d.name}</h4>`;
            if (d.type === 'class-duplicate') {
                html += `<p><em>Duplicate for self-property</em></p>`;
            } else {
                html += `<p><em>${expandedNodeIds.has(d.id) ? 'Expanded' : 'Collapsed'}</em></p>`;
            }

            tooltip.html(html)
                .style("display", "block")
                .style("left", (event.pageX + 10) + "px")
                .style("top", (event.pageY - 28) + "px");
        }

        function showLinkTooltip(event, d) {
            let html = `<h4>${d.property}</h4>`;
            html += `<p><strong>Type:</strong> ${d.type}</p>`;

            tooltip.html(html)
                .style("display", "block")
                .style("left", (event.pageX + 10) + "px")
                .style("top", (event.pageY - 28) + "px");
        }

        function hideTooltip() {
            tooltip.style("display", "none");
        }

        function dragstarted(event, d) {
            d.dragging = true;
            d3.select(this).classed("dragging", true);
        }

        function dragged(event, d) {
            d.x = event.x;
            d.y = event.y;
            updatePositions();
        }

        function dragended(event, d) {
            d.dragging = false;
            d3.select(this).classed("dragging", false);
        }

        function setupControls() {
            // Search
            d3.select("#searchInput").on("input", function() {
                const search = this.value.toLowerCase().trim();
                if (search === "") {
                    // Don't change the graph when search is empty
                    return;
                }

                // Search across all nodes (match from start of name)
                const matchingNodes = allNodes.filter(node =>
                    node.name.toLowerCase().startsWith(search) &&
                    node.type !== 'class-duplicate'
                );

                if (matchingNodes.length > 0) {
                    // Use the first match
                    const targetNode = matchingNodes[0];

                    // Clear and expand the found node
                    visibleNodeIds.clear();
                    expandedNodeIds.clear();
                    visibleNodeIds.add(targetNode.id);
                    expandNode(targetNode.id);

                    // Update visualization
                    updateVisualization();

                    // Show definition in sidebar
                    showDefinition(targetNode);
                }
            });

            // Link type filter
            d3.select("#linkTypeFilter").on("change", function() {
                const filter = this.value;
                linkElements.style("display", d => {
                    if (filter === "all") return "block";
                    return d.type === filter ? "block" : "none";
                });
                linkLabelGroups.style("display", d => {
                    if (filter === "all") return "block";
                    return d.type === filter ? "block" : "none";
                });
            });
        }

        function resetGraph() {
            visibleNodeIds.clear();
            expandedNodeIds.clear();

            const entityUri = 'http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Entity';
            visibleNodeIds.add(entityUri);
            expandNode(entityUri);

            updateVisualization();

            d3.select("#searchInput").property("value", "");
            d3.select("#linkTypeFilter").property("value", "all");

            svg.transition().duration(750).call(
                d3.zoom().transform,
                d3.zoomIdentity
            );
        }

        // Window resize handler
        window.addEventListener('resize', function() {
            const newWidth = window.innerWidth;
            const newHeight = window.innerHeight;

            svg.attr("width", newWidth).attr("height", newHeight);
            // Recalculate layout with new dimensions
            updateVisualization();
        });

        // Load ontology on page load
        loadOntology();
    </script>
</body>
</html>
